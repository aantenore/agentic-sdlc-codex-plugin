{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "output-template.schema.json",
  "title": "Agentic SDLC Output Template",
  "type": "object",
  "required": [
    "id",
    "type",
    "status",
    "path"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "status": {
      "enum": [
        "draft",
        "approved",
        "deprecated"
      ]
    },
    "path": {
      "type": "string"
    },
    "summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "preset": {
      "type": [
        "string",
        "null"
      ]
    },
    "delivery": {
      "$ref": "#/$defs/delivery"
    },
    "source_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proposed_at": {
      "type": "string"
    },
    "approved_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "approved_by": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "approved_content_hash": {
      "type": "string"
    },
    "approved_delivery_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "hash_algorithm": {
      "type": "string"
    },
    "approval_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "delivery": {
      "type": "object",
      "required": [
        "format",
        "label",
        "extension",
        "media_type",
        "generator",
        "mode"
      ],
      "properties": {
        "format": {
          "enum": [
            "markdown",
            "docx",
            "xlsx",
            "pdf",
            "pptx",
            "html",
            "json",
            "csv",
            "custom"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "extension": {
          "type": "string",
          "pattern": "^\\.[a-z0-9][a-z0-9._-]*$"
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        },
        "generator": {
          "type": [
            "string",
            "null"
          ]
        },
        "mode": {
          "enum": [
            "artifact",
            "artifact-plus-chat-summary"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
