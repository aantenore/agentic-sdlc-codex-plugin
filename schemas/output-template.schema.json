{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aantenore/agentic-sdlc-codex-plugin/schemas/output-template.schema.json",
  "title": "Agentic SDLC Output Template",
  "type": "object",
  "required": [
    "id",
    "type",
    "status",
    "path"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "status": {
      "enum": [
        "draft",
        "approved",
        "deprecated"
      ]
    },
    "path": {
      "type": "string"
    },
    "summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proposed_at": {
      "type": "string"
    },
    "approved_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "approved_by": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "approved_content_hash": {
      "type": "string"
    },
    "hash_algorithm": {
      "type": "string"
    },
    "approval_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
