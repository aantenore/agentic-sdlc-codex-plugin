{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "requirement-lifecycle-event.schema.json",
  "title": "Agentic SDLC Requirement Lifecycle Event",
  "type": "object",
  "required": [
    "id",
    "kind",
    "schema_version",
    "event",
    "requirement_ref",
    "replacement_ref",
    "reason",
    "approval",
    "created_at",
    "audit"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": { "const": "requirement_lifecycle_event" },
    "schema_version": { "const": "requirement-lifecycle-event:v1" },
    "event": { "const": "superseded" },
    "requirement_ref": { "$ref": "#/$defs/ref" },
    "replacement_ref": { "$ref": "#/$defs/ref" },
    "reason": { "type": "string", "minLength": 1 },
    "approval": { "type": "object", "additionalProperties": true },
    "created_at": { "type": "string", "format": "date-time" },
    "audit": { "$ref": "common.schema.json#/$defs/audit" }
  },
  "$defs": {
    "ref": {
      "type": "object",
      "required": ["id", "path", "content_hash", "revision"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "content_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "revision": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
