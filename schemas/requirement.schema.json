{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "requirement.schema.json",
  "title": "Agentic SDLC Requirement v1",
  "type": "object",
  "required": [
    "id",
    "kind",
    "schema_version",
    "title",
    "summary",
    "status",
    "acceptance_criteria",
    "source_paths",
    "created_at",
    "updated_at",
    "audit"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "const": "requirement"
    },
    "schema_version": {
      "const": "requirement:v1"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "proposed",
        "approved",
        "active",
        "satisfied",
        "rejected",
        "superseded"
      ]
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      }
    },
    "proposal_ref": {
      "type": [
        "object",
        "null"
      ],
      "required": [
        "id",
        "hash"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "approval_ref": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "audit": {
      "$ref": "common.schema.json#/$defs/audit"
    }
  },
  "additionalProperties": false
}
