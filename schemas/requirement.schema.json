{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "requirement.schema.json",
  "title": "Agentic SDLC Requirement",
  "type": "object",
  "required": [
    "id",
    "kind",
    "schema_version",
    "title",
    "summary",
    "status",
    "acceptance_criteria",
    "source_paths",
    "created_at",
    "updated_at",
    "audit"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "const": "requirement"
    },
    "schema_version": {
      "enum": [
        "requirement:v1",
        "requirement:v2"
      ]
    },
    "logical_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "proposed",
        "approved",
        "active",
        "satisfied",
        "rejected",
        "superseded"
      ]
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_goals": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "constraints": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_functional_requirements": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "integrations": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      }
    },
    "proposal_ref": {
      "type": [
        "object",
        "null"
      ],
      "required": [
        "id",
        "hash"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "previous_revision_ref": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/hashed_requirement_ref"
        }
      ]
    },
    "autonomy_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "approval_ref": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "audit": {
      "$ref": "common.schema.json#/$defs/audit"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": "requirement:v2"
          }
        },
        "required": [
          "schema_version"
        ]
      },
      "then": {
        "required": [
          "logical_id",
          "revision",
          "source_hashes",
          "non_goals",
          "constraints",
          "non_functional_requirements",
          "integrations",
          "previous_revision_ref",
          "autonomy_profile_id",
          "approvals"
        ]
      }
    }
  ],
  "$defs": {
    "hashed_requirement_ref": {
      "type": "object",
      "required": [
        "id",
        "path",
        "content_hash",
        "revision"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "content_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
