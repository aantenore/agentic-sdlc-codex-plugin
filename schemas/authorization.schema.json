{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "authorization.schema.json",
  "title": "Agentic SDLC Delegated Automation Authorization (legacy-compatible)",
  "description": "Backward-compatible authorization record. New assessment workflows should use content-authorization.schema.json and immutable usage receipts.",
  "type": "object",
  "required": [
    "id",
    "status",
    "scope",
    "summary",
    "allowed_actions",
    "allowed_artifact_types",
    "allowed_subjects",
    "expires_at",
    "approval_source",
    "approval_evidence",
    "granted_by",
    "created_at",
    "updated_at",
    "approved_content_hash",
    "hash_algorithm",
    "audit"
  ],
  "properties": {
    "kind": {
      "enum": [
        "authorization",
        "content_authorization"
      ]
    },
    "schema_version": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "pending",
        "active",
        "consumed",
        "closed",
        "expired",
        "revoked"
      ]
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?:\\*|[a-z0-9][a-z0-9._-]*(?:\\.\\*)?)$"
      }
    },
    "allowed_uses": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": [
          "action",
          "subject_id",
          "use_hash"
        ],
        "properties": {
          "action": {
            "type": "string",
            "pattern": "^(?:\\*|[a-z0-9][a-z0-9._-]*(?:\\.\\*)?)$"
          },
          "subject_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "use_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        },
        "additionalProperties": false
      }
    },
    "allowed_artifact_types": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._-]*$"
      }
    },
    "allowed_approval_boundaries": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_subjects": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_subject_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      }
    },
    "proposal_ref": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": [
            "id",
            "hash"
          ],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "path": {
              "type": [
                "string",
                "null"
              ]
            },
            "hash": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "use_policy": {
      "type": "object",
      "additionalProperties": true
    },
    "authority_assurance": {
      "oneOf": [
        {
          "enum": [
            "audit_only",
            "host_verified"
          ]
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "approval_source": {
      "enum": [
        "explicit-user",
        "ci"
      ]
    },
    "approval_evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      }
    },
    "granted_by": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "approved_content_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "authorization_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "hash_algorithm": {
      "enum": [
        "sha256:stable-json:v1",
        "sha256:stable-json:v2"
      ]
    },
    "revoked_at": {
      "type": "string",
      "format": "date-time"
    },
    "revocation_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "revocations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "usage_receipts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "hash"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        },
        "additionalProperties": false
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": "authorization:v3"
          }
        },
        "required": [
          "schema_version"
        ]
      },
      "then": {
        "required": [
          "allowed_uses"
        ]
      }
    }
  ],
  "additionalProperties": true
}
