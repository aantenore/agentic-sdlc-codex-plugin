{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "authorization.schema.json",
  "title": "Agentic SDLC Delegated Automation Authorization",
  "type": "object",
  "required": [
    "id",
    "status",
    "scope",
    "summary",
    "allowed_actions",
    "allowed_artifact_types",
    "allowed_subjects",
    "expires_at",
    "approval_source",
    "approval_evidence",
    "granted_by",
    "created_at",
    "updated_at",
    "approved_content_hash",
    "hash_algorithm",
    "audit"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "active",
        "revoked"
      ]
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?:\\*|[a-z0-9][a-z0-9._-]*(?:\\.\\*)?)$"
      }
    },
    "allowed_artifact_types": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._-]*$"
      }
    },
    "allowed_approval_boundaries": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_subjects": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "approval_source": {
      "enum": [
        "explicit-user",
        "ci"
      ]
    },
    "approval_evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      }
    },
    "granted_by": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "approved_content_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "hash_algorithm": {
      "const": "sha256:stable-json:v1"
    },
    "revoked_at": {
      "type": "string",
      "format": "date-time"
    },
    "revocation_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "audit": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
