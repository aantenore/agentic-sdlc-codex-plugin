{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project.schema.json",
  "title": "Agentic SDLC Project",
  "type": "object",
  "required": [
    "project_id",
    "project_name",
    "schema_version",
    "sdlc_version",
    "knowledge_base"
  ],
  "properties": {
    "project_id": {
      "type": "string"
    },
    "project_name": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "sdlc_version": {
      "type": "string"
    },
    "knowledge_base": {
      "type": "object",
      "properties": {
        "storage": {
          "type": "string"
        },
        "canonical_path": {
          "type": "string"
        },
        "stateless_plugin": {
          "type": "boolean"
        },
        "concurrency_model": {
          "type": "string"
        },
        "source_of_truth": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "derived_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "output_contracts_registry": {
          "type": "string",
          "default": ".sdlc/output-contracts/registry.json"
        },
        "cache_policy_path": {
          "type": "string",
          "default": ".sdlc/cache/kb-cache.json"
        }
      },
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "properties": {
        "created_by": {
          "type": "object",
          "additionalProperties": true
        },
        "updated_by": {
          "type": "object",
          "additionalProperties": true
        },
        "git": {
          "type": "object",
          "additionalProperties": true
        },
        "run": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
