{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "assessment-application.schema.json",
  "title": "Agentic SDLC Assessment Application v1",
  "description": "Idempotent materialization receipt for one approved assessment proposal and its internal records.",
  "type": "object",
  "required": [
    "id",
    "kind",
    "schema_version",
    "status",
    "proposal_id",
    "proposal_hash",
    "authorization_ref",
    "authority_assurance",
    "write_results",
    "authorization_use_refs",
    "effective_budget",
    "budget_amendments",
    "applied_at",
    "applied_by",
    "audit",
    "application_hash",
    "hash_algorithm"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": { "const": "assessment_application" },
    "schema_version": { "const": "assessment-application:v1" },
    "status": { "enum": ["applied", "completed"] },
    "proposal_id": { "type": "string", "minLength": 1 },
    "proposal_hash": { "$ref": "#/$defs/sha256" },
    "authorization_ref": { "type": "string", "minLength": 1 },
    "authority_assurance": { "$ref": "content-authorization.schema.json#/$defs/authority_assurance" },
    "write_results": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/write_result" }
    },
    "authorization_use_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "effective_budget": { "$ref": "execution-budget.schema.json" },
    "budget_amendments": {
      "type": "array",
      "items": { "$ref": "#/$defs/budget_amendment_ref" }
    },
    "applied_at": { "type": "string", "format": "date-time" },
    "applied_by": { "$ref": "common.schema.json#/$defs/actor" },
    "updated_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "output_ref": { "$ref": "#/$defs/output_ref" },
    "release_manifest_ref": { "$ref": "#/$defs/release_manifest_ref" },
    "audit": { "$ref": "common.schema.json#/$defs/audit" },
    "application_hash": { "$ref": "#/$defs/sha256" },
    "hash_algorithm": { "const": "sha256:stable-json:v1" }
  },
  "if": {
    "properties": { "status": { "const": "completed" } }
  },
  "then": {
    "required": ["completed_at", "output_ref", "release_manifest_ref"]
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "write_result": {
      "type": "object",
      "required": ["kind", "id", "status", "path", "sha256"],
      "properties": {
        "kind": { "enum": ["requirement", "story", "output_template", "contract", "task_start"] },
        "id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["created", "reused", "created_and_approved"] },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "budget_amendment_ref": {
      "type": "object",
      "required": ["id", "path", "amendment_hash", "result_budget_hash"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "amendment_hash": { "$ref": "#/$defs/sha256" },
        "result_budget_hash": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "output_ref": {
      "type": "object",
      "required": ["id", "path", "verification_receipt_ref"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "verification_receipt_ref": { "$ref": "#/$defs/hashed_ref" }
      },
      "additionalProperties": false
    },
    "release_manifest_ref": {
      "type": "object",
      "required": ["id", "path", "manifest_hash"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "manifest_hash": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "hashed_ref": {
      "type": "object",
      "required": ["id", "path", "hash"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "hash": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
