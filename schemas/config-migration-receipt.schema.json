{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "config-migration-receipt.schema.json",
  "title": "Agentic SDLC Configuration Migration Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "schema_version",
    "status",
    "mode",
    "plan_hash",
    "config_path",
    "lock_path",
    "source_config_hash",
    "target_config_hash",
    "effective_config_hash",
    "defaults_profile",
    "inherited_paths",
    "changes",
    "lock_hash",
    "applied_at",
    "audit",
    "hash_algorithm",
    "receipt_hash"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^MIG-CONFIG-[a-f0-9]{16}$" },
    "kind": { "const": "config_migration_receipt" },
    "schema_version": { "const": "config-migration-receipt:v1" },
    "status": { "const": "applied" },
    "mode": { "enum": ["materialize_legacy_defaults", "adopt_lock", "reconcile_drift"] },
    "plan_hash": { "$ref": "#/$defs/sha256" },
    "config_path": { "$ref": "#/$defs/sdlc_path" },
    "lock_path": { "$ref": "#/$defs/sdlc_path" },
    "source_config_hash": { "$ref": "#/$defs/sha256" },
    "target_config_hash": { "$ref": "#/$defs/sha256" },
    "effective_config_hash": { "$ref": "#/$defs/sha256" },
    "defaults_profile": { "$ref": "#/$defs/defaults_profile" },
    "inherited_paths": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/json_pointer" }
    },
    "changes": {
      "type": "array",
      "items": { "$ref": "config-migration-plan.schema.json#/$defs/change" }
    },
    "lock_hash": { "$ref": "#/$defs/sha256" },
    "applied_at": { "type": "string", "format": "date-time" },
    "audit": { "$ref": "common.schema.json#/$defs/audit" },
    "hash_algorithm": { "const": "sha256:stable-json:v1" },
    "receipt_hash": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "sdlc_path": { "type": "string", "pattern": "^\\.sdlc/(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+$" },
    "json_pointer": { "type": "string", "pattern": "^/(?:[^~]|~[01])+$" },
    "defaults_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sha256"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
