{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "delivery-start-receipt.schema.json",
  "title": "Exact delivery start receipt",
  "type": "object",
  "required": [
    "id",
    "kind",
    "schema_version",
    "profile_ref",
    "delivery",
    "story_ref",
    "contract_ref",
    "contract_approval_hash",
    "phase",
    "route",
    "autonomy_decision_ref",
    "effective_level",
    "start_basis",
    "status",
    "started_by",
    "started_at",
    "audit",
    "receipt_hash",
    "hash_algorithm"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": { "const": "delivery_start_receipt" },
    "schema_version": { "const": "delivery-start-receipt:v1" },
    "profile_ref": { "$ref": "#/$defs/path_hashed_id_ref" },
    "delivery": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["pull_request", "local_release"] }
      },
      "additionalProperties": false
    },
    "story_ref": { "$ref": "#/$defs/path_hashed_id_ref" },
    "contract_ref": { "$ref": "#/$defs/path_hashed_id_ref" },
    "contract_approval_hash": { "$ref": "#/$defs/sha256" },
    "phase": { "enum": ["discovery", "analysis", "design", "implementation", "validation", "release"] },
    "route": { "type": "string", "minLength": 1 },
    "autonomy_decision_ref": { "$ref": "#/$defs/path_hashed_id_ref" },
    "effective_level": { "enum": ["supervised", "checkpointed", "bounded-autonomous"] },
    "start_basis": { "enum": ["explicit-confirmation", "checkpointed-profile", "bounded-autonomous-profile"] },
    "status": { "const": "started" },
    "started_by": { "$ref": "common.schema.json#/$defs/actor" },
    "started_at": { "type": "string", "format": "date-time" },
    "audit": { "$ref": "common.schema.json#/$defs/audit" },
    "receipt_hash": { "$ref": "#/$defs/sha256" },
    "hash_algorithm": { "const": "sha256:stable-json:v1" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "path_hashed_id_ref": {
      "type": "object",
      "required": ["id", "path", "hash"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "hash": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
