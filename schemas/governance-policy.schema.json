{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "governance-policy.schema.json",
  "title": "Exact default-deny governance policy",
  "type": "object",
  "required": [
    "kind",
    "schema_version",
    "version",
    "id",
    "status",
    "valid_from",
    "expires_at",
    "decision_ttl_seconds",
    "role_bindings",
    "rules",
    "created_at",
    "policy_hash",
    "hash_algorithm"
  ],
  "properties": {
    "kind": { "const": "governance_policy" },
    "schema_version": { "const": "governance-policy:v1" },
    "version": { "const": 1 },
    "id": { "$ref": "#/$defs/ref_id" },
    "status": { "const": "active" },
    "valid_from": { "type": "string", "format": "date-time" },
    "expires_at": { "type": ["string", "null"], "format": "date-time" },
    "decision_ttl_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
    "role_bindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/role_binding" }
    },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/rule" }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "policy_hash": { "$ref": "#/$defs/sha256" },
    "hash_algorithm": { "const": "sha256:stable-json:v1" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "exact_name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "ref_id": { "type": "string", "pattern": "^(?!\\.{1,2}(?:/|$))(?![^@]*@)[A-Za-z0-9.][A-Za-z0-9._:/+-]{0,511}$" },
    "actor": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": { "$ref": "#/$defs/exact_name" },
        "id": { "type": "string", "pattern": "^(?!\\.{1,2}(?:/|$))[A-Za-z0-9.][A-Za-z0-9._:/@+-]{0,511}$" },
        "issuer": { "type": "string", "pattern": "^(?!\\.{1,2}(?:/|$))[A-Za-z0-9.][A-Za-z0-9._:/@+-]{0,511}$" }
      },
      "additionalProperties": false
    },
    "ref": {
      "type": "object",
      "required": ["kind", "id"],
      "properties": {
        "kind": { "$ref": "#/$defs/exact_name" },
        "id": { "type": "string", "pattern": "^(?!\\.{1,2}(?:/|$))(?![^@]*@)[A-Za-z0-9.][A-Za-z0-9._:/+-]{0,511}$" },
        "hash": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "evidence_ref": {
      "allOf": [
        { "$ref": "#/$defs/ref" },
        { "required": ["hash"] }
      ]
    },
    "role_binding": {
      "type": "object",
      "required": ["id", "role", "actor", "valid_from", "expires_at"],
      "properties": {
        "id": { "$ref": "#/$defs/ref_id" },
        "role": { "$ref": "#/$defs/exact_name" },
        "actor": { "$ref": "#/$defs/actor" },
        "valid_from": { "type": "string", "format": "date-time" },
        "expires_at": { "type": ["string", "null"], "format": "date-time" }
      },
      "additionalProperties": false
    },
    "quorum": {
      "type": "object",
      "required": ["minimum", "roles", "distinct_identities"],
      "properties": {
        "minimum": { "type": "integer", "minimum": 1, "maximum": 32 },
        "roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/exact_name" }
        },
        "distinct_identities": { "const": true }
      },
      "additionalProperties": false
    },
    "sod": {
      "type": "object",
      "required": ["left_role", "right_role"],
      "properties": {
        "left_role": { "$ref": "#/$defs/exact_name" },
        "right_role": { "$ref": "#/$defs/exact_name" }
      },
      "additionalProperties": false
    },
    "rule": {
      "type": "object",
      "required": [
        "id",
        "effect",
        "action",
        "scope_refs",
        "evidence_refs",
        "actor_roles",
        "quorum",
        "separation_of_duties",
        "valid_from",
        "expires_at"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/ref_id" },
        "effect": { "enum": ["allow", "deny"] },
        "action": { "$ref": "#/$defs/exact_name" },
        "scope_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/ref" }
        },
        "evidence_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidence_ref" }
        },
        "actor_roles": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/exact_name" }
        },
        "quorum": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/quorum" }
          ]
        },
        "separation_of_duties": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/sod" }
        },
        "valid_from": { "type": "string", "format": "date-time" },
        "expires_at": { "type": ["string", "null"], "format": "date-time" }
      },
      "allOf": [
        {
          "if": { "properties": { "effect": { "const": "allow" } }, "required": ["effect"] },
          "then": { "properties": { "actor_roles": { "minItems": 1 } } },
          "else": {
            "properties": {
              "quorum": { "const": null },
              "separation_of_duties": { "maxItems": 0 }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
