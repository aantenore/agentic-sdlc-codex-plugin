{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aantenore/agentic-sdlc-codex-plugin/schemas/gate-report.schema.json",
  "title": "Agentic SDLC Gate Report",
  "type": "object",
  "required": [
    "status",
    "strict",
    "scope",
    "checked_at",
    "errors",
    "warnings",
    "checked"
  ],
  "properties": {
    "status": {
      "enum": [
        "passed",
        "failed"
      ]
    },
    "strict": {
      "type": "boolean"
    },
    "checked_at": {
      "type": "string"
    },
    "root": {
      "type": "string"
    },
    "scope": {
      "enum": [
        "story",
        "all"
      ]
    },
    "story_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "actor": {
      "type": "object",
      "additionalProperties": true
    },
    "git": {
      "type": "object",
      "additionalProperties": true
    },
    "run": {
      "type": "object",
      "additionalProperties": true
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checked": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
