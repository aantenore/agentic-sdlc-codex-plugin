{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "delivery-close-receipt.schema.json",
  "title": "Exact delivery terminal receipt",
  "type": "object",
  "required": [
    "id",
    "kind",
    "schema_version",
    "profile_ref",
    "delivery",
    "start_receipt_ref",
    "terminal_action_receipt_ref",
    "terminal_status",
    "reason",
    "approval",
    "closed_by",
    "closed_at",
    "audit",
    "receipt_hash",
    "hash_algorithm"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": { "const": "delivery_close_receipt" },
    "schema_version": { "const": "delivery-close-receipt:v1" },
    "profile_ref": { "$ref": "#/$defs/path_hashed_id_ref" },
    "delivery": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["pull_request", "local_release"] }
      },
      "additionalProperties": false
    },
    "start_receipt_ref": { "$ref": "#/$defs/path_hashed_id_ref" },
    "terminal_action_receipt_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/path_hashed_id_ref" }
      ]
    },
    "terminal_status": { "enum": ["merged", "closed", "released", "rolled_back", "cancelled", "superseded", "revoked"] },
    "reason": { "type": "string", "minLength": 1 },
    "approval": { "type": "object" },
    "closed_by": { "$ref": "common.schema.json#/$defs/actor" },
    "closed_at": { "type": "string", "format": "date-time" },
    "audit": { "$ref": "common.schema.json#/$defs/audit" },
    "receipt_hash": { "$ref": "#/$defs/sha256" },
    "hash_algorithm": { "const": "sha256:stable-json:v1" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "terminal_status": { "enum": ["merged", "released"] } },
        "required": ["terminal_status"]
      },
      "then": {
        "properties": { "terminal_action_receipt_ref": { "$ref": "#/$defs/path_hashed_id_ref" } }
      },
      "else": {
        "properties": {
          "terminal_action_receipt_ref": { "const": null },
          "approval": {
            "type": "object",
            "required": ["status"],
            "properties": { "status": { "const": "approved" } }
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "path_hashed_id_ref": {
      "type": "object",
      "required": ["id", "path", "hash"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "hash": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
