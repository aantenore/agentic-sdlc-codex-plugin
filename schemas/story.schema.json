{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aantenore/agentic-sdlc-codex-plugin/schemas/story.schema.json",
  "title": "Agentic SDLC Story",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "phase",
    "acceptance_criteria"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "enum": [
        "draft",
        "ready",
        "analysis",
        "design",
        "implementation",
        "in_progress",
        "review",
        "validation",
        "release",
        "done",
        "blocked"
      ]
    },
    "phase": {
      "enum": [
        "discovery",
        "analysis",
        "design",
        "implementation",
        "validation",
        "release"
      ]
    },
    "contract_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "work_breakdown_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "audit": {
      "type": "object",
      "properties": {
        "created_by": {
          "type": "object",
          "additionalProperties": true
        },
        "updated_by": {
          "type": "object",
          "additionalProperties": true
        },
        "git": {
          "type": "object",
          "additionalProperties": true
        },
        "run": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
