{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "story.schema.json",
  "title": "Agentic SDLC Story",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "phase",
    "acceptance_criteria"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "enum": [
        "draft",
        "ready",
        "analysis",
        "design",
        "implementation",
        "in_progress",
        "review",
        "validation",
        "release",
        "done",
        "blocked"
      ]
    },
    "phase": {
      "enum": [
        "discovery",
        "analysis",
        "design",
        "implementation",
        "validation",
        "release"
      ]
    },
    "contract_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "requirement_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["id", "path", "content_hash", "revision"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "content_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "revision": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    },
    "autonomy_ceiling": {
      "enum": ["supervised", "checkpointed", "bounded-autonomous"]
    },
    "work_breakdown_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Human-readable alias for acceptance_criteria. acceptance_criteria remains the canonical gate field."
    },
    "audit": {
      "type": "object",
      "properties": {
        "created_by": {
          "type": "object",
          "additionalProperties": true
        },
        "updated_by": {
          "type": "object",
          "additionalProperties": true
        },
        "git": {
          "type": "object",
          "additionalProperties": true
        },
        "run": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
