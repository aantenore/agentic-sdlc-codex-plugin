{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aantenore/travelops-sdlc-codex-plugin/schemas/story.schema.json",
  "title": "TravelOps SDLC Story",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "phase",
    "acceptance_criteria"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "phase": {
      "type": "string"
    },
    "contract_id": {
      "type": "string"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
