{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trace.schema.json",
  "title": "Agentic SDLC Trace Event",
  "type": "object",
  "required": [
    "id",
    "type",
    "summary",
    "actor",
    "action",
    "git",
    "run",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "story_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "type": {
      "enum": [
        "assumption",
        "decision",
        "gate",
        "claim",
        "handoff",
        "implementation",
        "lock",
        "release",
        "risk",
        "sync",
        "test"
      ]
    },
    "summary": {
      "type": "string"
    },
    "outcome": {
      "enum": [
        "passed",
        "failed",
        "blocked",
        "skipped",
        "ready",
        null
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "narrative": {
      "type": "object",
      "properties": {
        "schema_version": {
          "const": "trace-narrative:v1"
        },
        "input_summaries": {
          "type": "array",
          "items": { "type": "string" }
        },
        "output_summaries": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rationale_summary": {
          "type": ["string", "null"]
        },
        "alternatives": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "explanation": {
          "type": "object",
          "required": ["text", "kind", "scope"],
          "properties": {
            "text": { "type": "string" },
            "kind": {
              "enum": ["codex-generated", "deterministic", "human-authored"]
            },
            "scope": { "const": "recorded-evidence-only" }
          },
          "additionalProperties": false
        },
        "input_summary": {
          "type": ["string", "array"],
          "items": { "type": "string" }
        },
        "output_summary": {
          "type": ["string", "array"],
          "items": { "type": "string" }
        },
        "rationale": { "type": "string" },
        "generated_explanation": { "type": "string" },
        "explanation_source": {
          "enum": ["codex-generated", "deterministic", "human", "human-authored"]
        },
        "chain_of_thought_included": { "const": false }
      },
      "additionalProperties": false
    },
    "actor": {
      "$ref": "#/$defs/actor"
    },
    "requested_by": {
      "$ref": "#/$defs/actor"
    },
    "authorized_by": {
      "$ref": "#/$defs/actor"
    },
    "request": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "id": {
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "type": [
            "string",
            "null"
          ]
        },
        "thread_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "run_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "session_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "action": {
      "type": "string"
    },
    "git": {
      "type": "object",
      "properties": {
        "event": {
          "type": [
            "string",
            "null"
          ]
        },
        "branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "head_sha": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "run": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string"
    }
  },
  "additionalProperties": true,
  "$defs": {
    "actor": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": [
            "id",
            "type"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "type": {
              "enum": [
                "human",
                "agent",
                "system",
                "ci",
                "unknown"
              ]
            },
            "name": {
              "type": [
                "string",
                "null"
              ]
            },
            "email": {
              "type": [
                "string",
                "null"
              ]
            },
            "source": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      ]
    }
  }
}
