{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aantenore/agentic-sdlc-codex-plugin/schemas/trace.schema.json",
  "title": "Agentic SDLC Trace Event",
  "type": "object",
  "required": [
    "id",
    "type",
    "summary",
    "actor",
    "action",
    "git",
    "run",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "story_id": {
      "type": "string"
    },
    "type": {
      "enum": [
        "assumption",
        "decision",
        "gate",
        "claim",
        "handoff",
        "implementation",
        "lock",
        "release",
        "risk",
        "sync",
        "test"
      ]
    },
    "summary": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "actor": {
      "$ref": "#/$defs/actor"
    },
    "requested_by": {
      "$ref": "#/$defs/actor"
    },
    "authorized_by": {
      "$ref": "#/$defs/actor"
    },
    "request": {
      "type": "object",
      "properties": {
        "id": {
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "type": [
            "string",
            "null"
          ]
        },
        "thread_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "run_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "session_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "action": {
      "type": "string"
    },
    "git": {
      "type": "object",
      "properties": {
        "event": {
          "type": [
            "string",
            "null"
          ]
        },
        "branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "head_sha": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "run": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string"
    }
  },
  "additionalProperties": true,
  "$defs": {
    "actor": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": [
            "id",
            "type"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "type": {
              "enum": [
                "human",
                "agent",
                "system",
                "ci",
                "unknown"
              ]
            },
            "name": {
              "type": [
                "string",
                "null"
              ]
            },
            "email": {
              "type": [
                "string",
                "null"
              ]
            },
            "source": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      ]
    }
  }
}
