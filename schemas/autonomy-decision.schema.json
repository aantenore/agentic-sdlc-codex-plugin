{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "autonomy-decision.schema.json",
  "title": "Agentic SDLC Autonomy Decision v1",
  "type": "object",
  "required": [
    "kind",
    "schema_version",
    "version",
    "id",
    "delivery",
    "phase",
    "requested_level",
    "effective_level",
    "execution_status",
    "requires_human_approval",
    "requires_checkpoint",
    "autonomous",
    "blocked",
    "source_constraints",
    "reason_codes",
    "material_drift",
    "evaluated_at",
    "decision_hash",
    "hash_algorithm"
  ],
  "properties": {
    "kind": { "const": "autonomy_decision" },
    "schema_version": { "const": "autonomy-decision:v1" },
    "version": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "minLength": 1 },
    "delivery": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/delivery_ref" }
      ]
    },
    "phase": {
      "type": ["string", "null"],
      "enum": [null, "discovery", "analysis", "design", "implementation", "validation", "release"]
    },
    "requested_level": { "$ref": "#/$defs/autonomy_level" },
    "effective_level": { "$ref": "#/$defs/autonomy_level" },
    "execution_status": { "enum": ["blocked", "approval_required", "checkpoint_required", "ready"] },
    "requires_human_approval": { "type": "boolean" },
    "requires_checkpoint": { "type": "boolean" },
    "autonomous": { "type": "boolean" },
    "blocked": { "type": "boolean" },
    "source_constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source", "level", "valid", "blocked", "reason_codes"],
        "properties": {
          "source": { "type": "string", "minLength": 1 },
          "level": { "$ref": "#/$defs/autonomy_level" },
          "valid": { "type": "boolean" },
          "blocked": { "type": "boolean" },
          "reason_codes": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" }
          }
        },
        "additionalProperties": false
      }
    },
    "reason_codes": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" }
    },
    "material_drift": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "reason_code", "approved_hash", "current_hash"],
        "properties": {
          "field": { "type": "string", "minLength": 1 },
          "reason_code": { "type": "string", "pattern": "^material_drift\\.[a-z0-9._-]+$" },
          "approved_hash": { "$ref": "#/$defs/sha256" },
          "current_hash": { "$ref": "#/$defs/sha256" }
        },
        "additionalProperties": false
      }
    },
    "evaluated_at": { "type": "string", "format": "date-time" },
    "decision_hash": { "$ref": "#/$defs/sha256" },
    "hash_algorithm": { "const": "sha256:stable-json:v1" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "execution_status": { "const": "blocked" } },
        "required": ["execution_status"]
      },
      "then": {
        "properties": {
          "blocked": { "const": true },
          "effective_level": { "const": "supervised" },
          "requires_human_approval": { "const": false },
          "requires_checkpoint": { "const": false },
          "autonomous": { "const": false }
        }
      }
    },
    {
      "if": {
        "properties": { "execution_status": { "const": "approval_required" } },
        "required": ["execution_status"]
      },
      "then": {
        "properties": {
          "blocked": { "const": false },
          "effective_level": { "const": "supervised" },
          "requires_human_approval": { "const": true },
          "requires_checkpoint": { "const": false },
          "autonomous": { "const": false }
        }
      }
    },
    {
      "if": {
        "properties": { "execution_status": { "const": "checkpoint_required" } },
        "required": ["execution_status"]
      },
      "then": {
        "properties": {
          "blocked": { "const": false },
          "delivery": { "$ref": "#/$defs/delivery_ref" },
          "effective_level": { "const": "checkpointed" },
          "requires_human_approval": { "const": false },
          "requires_checkpoint": { "const": true },
          "autonomous": { "const": false }
        }
      }
    },
    {
      "if": {
        "properties": { "execution_status": { "const": "ready" } },
        "required": ["execution_status"]
      },
      "then": {
        "properties": {
          "blocked": { "const": false },
          "delivery": { "$ref": "#/$defs/delivery_ref" },
          "effective_level": { "const": "bounded-autonomous" },
          "requires_human_approval": { "const": false },
          "requires_checkpoint": { "const": false },
          "autonomous": { "const": true }
        }
      }
    },
    {
      "if": {
        "properties": { "requested_level": { "const": "supervised" } },
        "required": ["requested_level"]
      },
      "then": {
        "properties": { "effective_level": { "const": "supervised" } }
      }
    },
    {
      "if": {
        "properties": { "requested_level": { "const": "checkpointed" } },
        "required": ["requested_level"]
      },
      "then": {
        "properties": {
          "effective_level": { "enum": ["supervised", "checkpointed"] }
        }
      }
    }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "autonomy_level": { "enum": ["supervised", "checkpointed", "bounded-autonomous"] },
    "delivery_ref": {
      "type": "object",
      "required": ["id", "kind", "profile_id", "profile_hash"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["pull_request", "local_release"] },
        "profile_id": { "type": "string", "minLength": 1 },
        "profile_hash": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
