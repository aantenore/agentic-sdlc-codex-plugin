{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "common.schema.json",
  "title": "Agentic SDLC Common Definitions",
  "$defs": {
    "actor": {
      "type": "object",
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "enum": [
            "human",
            "agent",
            "system",
            "ci",
            "unknown"
          ]
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "email": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "git": {
      "type": "object",
      "properties": {
        "is_git_repo": {
          "type": "boolean"
        },
        "branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "head_sha": {
          "type": [
            "string",
            "null"
          ]
        },
        "is_dirty": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "event": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "run": {
      "type": "object",
      "properties": {
        "run_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "thread_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "session_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "tool": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
