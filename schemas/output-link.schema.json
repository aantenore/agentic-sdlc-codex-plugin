{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "output-link.schema.json",
  "title": "Agentic SDLC Output Link",
  "type": "object",
  "required": [
    "id",
    "story_id",
    "artifact_type",
    "artifact_path",
    "template_id",
    "mode"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "story_id": {
      "type": "string"
    },
    "artifact_type": {
      "type": "string"
    },
    "artifact_path": {
      "type": "string"
    },
    "template_id": {
      "type": "string"
    },
    "mode": {
      "enum": [
        "reuse",
        "delta",
        "new"
      ]
    },
    "base_artifact": {
      "type": [
        "string",
        "null"
      ]
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "rationale": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "delivery_format": {
      "description": "Canonical delivery format snapshot copied from the approved output template.",
      "enum": [
        "markdown",
        "docx",
        "xlsx",
        "pdf",
        "pptx",
        "html",
        "json",
        "csv",
        "custom"
      ]
    },
    "delivery_extension": {
      "description": "Canonical extension snapshot copied from the approved output template.",
      "type": "string",
      "pattern": "^\\.[a-z0-9][a-z0-9._-]*$"
    },
    "media_type": {
      "description": "Canonical media type snapshot copied from the approved output template.",
      "type": "string",
      "minLength": 1
    },
    "generator": {
      "description": "Artifact capability snapshot copied from the approved output template.",
      "type": [
        "string",
        "null"
      ]
    },
    "delivery_mode": {
      "description": "Delivery mode snapshot copied from the approved output template.",
      "enum": [
        "artifact",
        "artifact-plus-chat-summary"
      ]
    },
    "verification_receipt": {
      "$ref": "verification-receipt.schema.json"
    },
    "verification_receipt_ref": {
      "description": "Optional v1 layered verification receipt stored as a canonical file.",
      "$ref": "#/$defs/hashed_ref"
    },
    "authorization_ref": {
      "description": "Content authorization consumed for a proposal-bound output link.",
      "type": ["string", "null"]
    },
    "authorization_use_ref": {
      "description": "Canonical historical-at-use receipt proving output.link authority.",
      "type": ["string", "null"]
    },
    "authorization_action": {
      "description": "Exact action consumed by authorization_use_ref.",
      "enum": ["output.link", null]
    },
    "legacy_verification_receipt": {
      "description": "Read-only compatibility payload for output links created before canonical verification-receipt:v1. New writers must use verification_receipt and verification_receipt_ref.",
      "$ref": "#/$defs/legacy_verification_receipt"
    },
    "fingerprints": {
      "type": "object",
      "required": [
        "artifact_sha256",
        "hash_algorithm"
      ],
      "properties": {
        "kind": {
          "const": "verification_receipt"
        },
        "schema_version": {
          "const": "verification-receipt:v1"
        },
        "id": {
          "type": "string"
        },
        "artifact_sha256": {
          "type": "string"
        },
        "base_artifact_sha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "template_sha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "hash_algorithm": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "legacy_verification_receipt": {
      "type": "object",
      "required": [
        "status",
        "verifier",
        "format",
        "checks",
        "evidence",
        "artifact_sha256",
        "verified_at"
      ],
      "properties": {
        "status": {
          "const": "passed"
        },
        "verifier": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "enum": [
            "markdown",
            "docx",
            "xlsx",
            "pdf",
            "pptx",
            "html",
            "json",
            "csv",
            "custom"
          ]
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "artifact_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "verified_at": {
          "type": "string",
          "format": "date-time"
        },
        "generator_receipt": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/legacy_receipt_ref"
            }
          ]
        },
        "container_verified": {
          "$ref": "#/$defs/legacy_verification_dimension"
        },
        "content_verified": {
          "$ref": "#/$defs/legacy_verification_dimension"
        },
        "render_verified": {
          "$ref": "#/$defs/legacy_verification_dimension"
        },
        "receipt_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "hashed_ref": {
      "type": "object",
      "required": [
        "id",
        "path",
        "hash"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "legacy_receipt_ref": {
      "type": "object",
      "required": [
        "path",
        "hash"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "legacy_verification_dimension": {
      "oneOf": [
        { "type": "boolean" },
        {
          "type": "object",
          "required": ["status", "checks"],
          "properties": {
            "status": {
              "enum": ["passed", "failed", "not_required", "verified", "not-required", "not-run"]
            },
            "checks": { "type": "array", "items": { "type": "string" } },
            "evidence": { "type": "array" }
          },
          "additionalProperties": true
        }
      ]
    },
    "evidence": {
      "type": "object",
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
  "dependentRequired": {
    "authorization_ref": ["authorization_use_ref", "authorization_action"],
    "authorization_use_ref": ["authorization_ref", "authorization_action"],
    "authorization_action": ["authorization_ref", "authorization_use_ref"]
  },
  "additionalProperties": false
}
  },
  "additionalProperties": true
}
