{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "output-link.schema.json",
  "title": "Agentic SDLC Output Link",
  "type": "object",
  "required": [
    "id",
    "story_id",
    "artifact_type",
    "artifact_path",
    "template_id",
    "mode"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "story_id": {
      "type": "string"
    },
    "artifact_type": {
      "type": "string"
    },
    "artifact_path": {
      "type": "string"
    },
    "template_id": {
      "type": "string"
    },
    "mode": {
      "enum": [
        "reuse",
        "delta",
        "new"
      ]
    },
    "base_artifact": {
      "type": [
        "string",
        "null"
      ]
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "rationale": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "delivery_format": {
      "description": "Canonical delivery format snapshot copied from the approved output template.",
      "enum": [
        "markdown",
        "docx",
        "xlsx",
        "pdf",
        "pptx",
        "html",
        "json",
        "csv",
        "custom"
      ]
    },
    "delivery_extension": {
      "description": "Canonical extension snapshot copied from the approved output template.",
      "type": "string",
      "pattern": "^\\.[a-z0-9][a-z0-9._-]*$"
    },
    "media_type": {
      "description": "Canonical media type snapshot copied from the approved output template.",
      "type": "string",
      "minLength": 1
    },
    "generator": {
      "description": "Artifact capability snapshot copied from the approved output template.",
      "type": [
        "string",
        "null"
      ]
    },
    "delivery_mode": {
      "description": "Delivery mode snapshot copied from the approved output template.",
      "enum": [
        "artifact",
        "artifact-plus-chat-summary"
      ]
    },
    "verification_receipt": {
      "$ref": "#/$defs/verification_receipt"
    },
    "fingerprints": {
      "type": "object",
      "required": [
        "artifact_sha256",
        "hash_algorithm"
      ],
      "properties": {
        "artifact_sha256": {
          "type": "string"
        },
        "base_artifact_sha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "template_sha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "hash_algorithm": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "verification_receipt": {
      "type": "object",
      "required": [
        "status",
        "verifier",
        "format",
        "checks",
        "evidence",
        "artifact_sha256",
        "verified_at"
      ],
      "properties": {
        "status": {
          "const": "passed"
        },
        "verifier": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "enum": [
            "markdown",
            "docx",
            "xlsx",
            "pdf",
            "pptx",
            "html",
            "json",
            "csv",
            "custom"
          ]
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "artifact_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "verified_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
