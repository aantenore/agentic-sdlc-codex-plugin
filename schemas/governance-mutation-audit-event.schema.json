{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "governance-mutation-audit-event.schema.json",
  "title": "Immutable mutation-governance audit event",
  "type": "object",
  "required": [
    "kind",
    "schema_version",
    "version",
    "recorded_at",
    "summary",
    "canonical_action",
    "command_path",
    "operation",
    "project_path",
    "reason_codes",
    "decision_ref",
    "error_digest",
    "event_hash",
    "hash_algorithm"
  ],
  "properties": {
    "kind": { "const": "governance_mutation_audit_event" },
    "schema_version": { "const": "governance-mutation-audit-event:v1" },
    "version": { "const": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "summary": {
      "const": "Audit observed a denied or failed mutation decision; the configured audit mode allowed execution to continue."
    },
    "canonical_action": { "type": ["string", "null"], "maxLength": 128 },
    "command_path": { "type": ["string", "null"], "maxLength": 512 },
    "operation": { "type": ["string", "null"], "maxLength": 128 },
    "project_path": { "type": ["string", "null"], "maxLength": 4096 },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": { "type": "string", "minLength": 1, "maxLength": 128 }
    },
    "decision_ref": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["id", "hash", "result"],
          "properties": {
            "id": { "type": "string", "minLength": 1, "maxLength": 512 },
            "hash": { "$ref": "#/$defs/sha256" },
            "result": { "enum": ["allow", "deny"] }
          },
          "additionalProperties": false
        }
      ]
    },
    "error_digest": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/sha256" }
      ]
    },
    "event_hash": { "$ref": "#/$defs/sha256" },
    "hash_algorithm": { "const": "sha256:stable-json:v1" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "additionalProperties": false
}
