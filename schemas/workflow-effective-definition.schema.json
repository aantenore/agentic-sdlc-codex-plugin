{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workflow-effective-definition.schema.json",
  "title": "Pinned effective workflow definition",
  "type": "object",
  "required": [
    "kind", "schema_version", "definition_ref", "overlay_ref", "id", "version", "label", "description",
    "initial_state", "states", "transitions", "phase_order", "normal_checkpoints", "metadata",
    "hash_algorithm", "effective_hash"
  ],
  "properties": {
    "kind": { "const": "effective_workflow_definition" },
    "schema_version": { "const": "effective-workflow-definition:v1" },
    "definition_ref": { "$ref": "workflow-overlay.schema.json#/properties/definition_ref" },
    "overlay_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "workflow-overlay.schema.json#/$defs/overlay_ref" }
      ]
    },
    "id": { "type": "string", "minLength": 1 },
    "version": { "$ref": "workflow-definition.schema.json#/$defs/version" },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "initial_state": { "type": "string", "minLength": 1 },
    "states": { "$ref": "workflow-definition.schema.json#/properties/states" },
    "transitions": { "$ref": "workflow-definition.schema.json#/properties/transitions" },
    "phase_order": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "normal_checkpoints": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "metadata": { "type": "object" },
    "hash_algorithm": { "const": "sha256:stable-json:v1" },
    "effective_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "additionalProperties": false
}
