{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "work-item.schema.json",
  "title": "Agentic SDLC Work Item",
  "type": "object",
  "required": [
    "id",
    "type",
    "title",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "enum": [
        "epic",
        "task"
      ]
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "parent_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "story_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "requirement_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
