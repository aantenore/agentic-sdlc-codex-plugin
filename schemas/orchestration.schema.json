{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aantenore/agentic-sdlc-codex-plugin/schemas/orchestration.schema.json",
  "title": "Agentic SDLC Orchestration Snapshot",
  "type": "object",
  "required": [
    "checked_at",
    "summary",
    "stories"
  ],
  "properties": {
    "checked_at": {
      "type": "string"
    },
    "root": {
      "type": "string"
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    },
    "stories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "orchestration_state"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "orchestration_state": {
            "enum": [
              "available",
              "claimed",
              "blocked",
              "stale"
            ]
          },
          "blockers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "locks": {
      "type": "array"
    },
    "handoffs": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
