{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "autonomy-profile-revocation.schema.json",
  "title": "Exact delivery autonomy profile revocation",
  "type": "object",
  "required": [
    "id",
    "kind",
    "schema_version",
    "profile_ref",
    "reason",
    "approval",
    "created_at",
    "audit",
    "receipt_hash",
    "hash_algorithm"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": { "const": "autonomy_profile_revocation" },
    "schema_version": { "const": "autonomy-profile-revocation:v1" },
    "profile_ref": { "$ref": "#/$defs/path_hashed_id_ref" },
    "reason": { "type": "string", "minLength": 1 },
    "approval": { "type": "object" },
    "created_at": { "type": "string", "format": "date-time" },
    "audit": { "$ref": "common.schema.json#/$defs/audit" },
    "receipt_hash": { "$ref": "#/$defs/sha256" },
    "hash_algorithm": { "const": "sha256:stable-json:v1" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "path_hashed_id_ref": {
      "type": "object",
      "required": ["id", "path", "hash"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "hash": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
