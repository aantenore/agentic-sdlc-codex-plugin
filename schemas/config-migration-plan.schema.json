{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "config-migration-plan.schema.json",
  "title": "Agentic SDLC Configuration Migration Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "status",
    "mode",
    "config_path",
    "lock_path",
    "source_config_hash",
    "source_lock_hash",
    "target_config_hash",
    "effective_config_hash",
    "defaults_profile",
    "inherited_paths",
    "changes",
    "target_config",
    "hash_algorithm",
    "plan_hash"
  ],
  "properties": {
    "kind": { "const": "config_migration_plan" },
    "schema_version": { "const": "config-migration-plan:v1" },
    "status": { "enum": ["ready", "already_applied"] },
    "mode": { "enum": ["materialize_legacy_defaults", "adopt_lock", "reconcile_drift", "already_locked"] },
    "config_path": { "$ref": "#/$defs/sdlc_path" },
    "lock_path": { "$ref": "#/$defs/sdlc_path" },
    "source_config_hash": { "$ref": "#/$defs/sha256" },
    "source_lock_hash": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/sha256" }
      ]
    },
    "target_config_hash": { "$ref": "#/$defs/sha256" },
    "effective_config_hash": { "$ref": "#/$defs/sha256" },
    "defaults_profile": { "$ref": "#/$defs/defaults_profile" },
    "inherited_paths": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/json_pointer" }
    },
    "changes": {
      "type": "array",
      "items": { "$ref": "#/$defs/change" }
    },
    "target_config": { "type": "object" },
    "hash_algorithm": { "const": "sha256:stable-json:v1" },
    "plan_hash": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "sdlc_path": { "type": "string", "pattern": "^\\.sdlc/(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+$" },
    "json_pointer": { "type": "string", "pattern": "^/(?:[^~]|~[01])+$" },
    "defaults_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sha256"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "change": {
      "type": "object",
      "required": ["operation", "path"],
      "properties": {
        "operation": { "enum": ["add", "remove", "replace"] },
        "path": { "type": "string" },
        "before": true,
        "after": true
      },
      "allOf": [
        {
          "if": { "properties": { "operation": { "const": "add" } }, "required": ["operation"] },
          "then": { "required": ["after"] }
        },
        {
          "if": { "properties": { "operation": { "const": "remove" } }, "required": ["operation"] },
          "then": { "required": ["before"] }
        },
        {
          "if": { "properties": { "operation": { "const": "replace" } }, "required": ["operation"] },
          "then": { "required": ["before", "after"] }
        }
      ],
      "additionalProperties": false
    }
  }
}
