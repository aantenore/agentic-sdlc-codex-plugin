{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "release-gate-receipt.schema.json",
  "title": "Agentic SDLC Release Gate Receipt v1",
  "description": "Immutable result of deterministic release checks for one manifest and proposal.",
  "type": "object",
  "required": [
    "kind",
    "schema_version",
    "version",
    "id",
    "status",
    "scope",
    "checks",
    "generated_at",
    "actor",
    "audit",
    "receipt_hash",
    "hash_algorithm"
  ],
  "properties": {
    "kind": { "const": "release_gate_receipt" },
    "schema_version": { "const": "release-gate-receipt:v1" },
    "version": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["passed", "failed"] },
    "scope": {
      "type": "object",
      "required": ["manifest_id", "proposal_ref"],
      "properties": {
        "manifest_id": { "type": "string", "minLength": 1 },
        "proposal_ref": { "$ref": "#/$defs/hashed_ref" }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "status", "subject_hash", "evidence"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": { "enum": ["passed", "failed", "not_required"] },
          "subject_hash": { "$ref": "#/$defs/sha256" },
          "evidence": {
            "type": "array",
            "items": { "$ref": "#/$defs/hashed_ref" }
          }
        },
        "additionalProperties": false
      }
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "actor": { "$ref": "common.schema.json#/$defs/actor" },
    "audit": { "$ref": "#/$defs/audit" },
    "receipt_hash": { "$ref": "#/$defs/sha256" },
    "hash_algorithm": { "const": "sha256:stable-json:v1" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "hashed_ref": {
      "type": "object",
      "required": ["id", "path", "hash"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "hash": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "audit": {
      "type": "object",
      "required": ["git", "run"],
      "properties": {
        "git": { "$ref": "common.schema.json#/$defs/git" },
        "run": { "$ref": "common.schema.json#/$defs/run" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
