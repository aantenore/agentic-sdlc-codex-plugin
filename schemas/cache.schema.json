{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cache.schema.json",
  "title": "Agentic SDLC Local Cache",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "source_paths",
    "source_hashes"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "root": {
      "type": "string"
    },
    "source_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "full_text_index": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "title",
          "extension",
          "size_bytes",
          "snippet",
          "search_text",
          "source_paths",
          "source_hashes",
          "generated_at",
          "schema_version"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "extension": {
            "type": "string"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "snippet": {
            "type": "string"
          },
          "search_text": {
            "type": "string"
          },
          "source_paths": {
            "$ref": "#/$defs/source_paths"
          },
          "source_hashes": {
            "$ref": "#/$defs/source_hashes"
          },
          "generated_at": {
            "type": "string",
            "format": "date-time"
          },
          "schema_version": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "story_requirement_graph": {
      "type": "array"
    },
    "artifact_fingerprints": {
      "type": "array"
    },
    "template_resolution": {
      "type": "object"
    },
    "kb_summaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "title",
          "snippet",
          "source_paths",
          "source_hashes",
          "generated_at",
          "schema_version"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "snippet": {
            "type": "string"
          },
          "source_paths": {
            "$ref": "#/$defs/source_paths"
          },
          "source_hashes": {
            "$ref": "#/$defs/source_hashes"
          },
          "generated_at": {
            "type": "string",
            "format": "date-time"
          },
          "schema_version": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "dependency_graph": {
      "type": "object"
    },
    "output_resolutions": {
      "type": "object"
    }
  },
  "$defs": {
    "source_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
