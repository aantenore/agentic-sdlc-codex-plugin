{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aantenore/agentic-sdlc-codex-plugin/schemas/handoff.schema.json",
  "title": "Agentic SDLC Story Handoff",
  "type": "object",
  "required": [
    "id",
    "story_id",
    "from_actor",
    "to_agent",
    "status",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "story_id": {
      "type": "string"
    },
    "from_actor": {
      "type": "object",
      "additionalProperties": true
    },
    "to_agent": {
      "type": "string"
    },
    "status": {
      "enum": [
        "open",
        "accepted",
        "closed",
        "rejected"
      ]
    },
    "summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "required_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_items": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
