{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "execution-budget.schema.json",
  "title": "Agentic SDLC Execution Budget v1",
  "type": "object",
  "required": [
    "kind",
    "schema_version",
    "version",
    "id",
    "scope",
    "warning_thresholds_percent",
    "completion_reserve_percent",
    "limits",
    "limit_policy",
    "extensions",
    "budget_hash",
    "hash_algorithm"
  ],
  "properties": {
    "kind": { "const": "execution_budget" },
    "schema_version": { "const": "execution-budget:v1" },
    "version": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "minLength": 1 },
    "scope": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "object", "additionalProperties": true }
      ]
    },
    "warning_thresholds_percent": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "default": [70, 90],
      "items": { "type": "integer", "minimum": 1, "maximum": 99 }
    },
    "completion_reserve_percent": {
      "type": "integer",
      "minimum": 0,
      "maximum": 50,
      "default": 15
    },
    "limits": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
      "additionalProperties": { "$ref": "#/$defs/metric_limit" }
    },
    "limit_policy": {
      "type": "object",
      "required": ["on_warning", "on_soft_limit", "on_hard_limit", "on_metering_violation"],
      "properties": {
        "on_warning": { "type": "string", "minLength": 1 },
        "on_soft_limit": { "enum": ["checkpoint", "partial_delivery", "stop"] },
        "on_hard_limit": { "const": "stop" },
        "on_metering_violation": { "const": "stop" }
      },
      "additionalProperties": false
    },
    "usage": {
      "description": "Optional live snapshot; canonical usage history is stored in execution-usage receipts.",
      "type": "object",
      "properties": {
        "values": { "type": "object", "additionalProperties": { "$ref": "#/$defs/quantity" } },
        "reservations": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": false
    },
    "extensions": {
      "description": "Configurable policy data such as on_limit, aggregation, active-time definition, and automatic-extension boundary.",
      "type": "object",
      "additionalProperties": true
    },
    "budget_hash": { "$ref": "#/$defs/sha256" },
    "hash_algorithm": { "const": "sha256:stable-json:v1" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "decimal_string": { "type": "string", "pattern": "^(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$" },
    "quantity": {
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        { "$ref": "#/$defs/decimal_string" }
      ]
    },
    "nullable_quantity": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/quantity" }
      ]
    },
    "metric_limit": {
      "type": "object",
      "required": ["unit", "metering", "soft", "hard", "currency"],
      "properties": {
        "unit": { "type": "string", "minLength": 1 },
        "metering": { "enum": ["exact", "estimated", "unavailable"] },
        "soft": { "$ref": "#/$defs/nullable_quantity" },
        "hard": { "$ref": "#/$defs/nullable_quantity" },
        "currency": {
          "type": ["string", "null"],
          "pattern": "^[A-Z][A-Z0-9]{2,7}$"
        }
      },
      "allOf": [
        {
          "not": {
            "properties": { "soft": { "type": "null" }, "hard": { "type": "null" } },
            "required": ["soft", "hard"]
          }
        },
        {
          "if": {
            "properties": { "hard": { "not": { "type": "null" } } },
            "required": ["hard"]
          },
          "then": { "properties": { "metering": { "const": "exact" } } }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
