{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aantenore/agentic-sdlc-codex-plugin/schemas/route-intent.schema.json",
  "title": "Agentic SDLC Canonical Route Intent",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "requested_action",
    "confidence",
    "referenced_entities",
    "provided_artifacts",
    "missing_context",
    "proposed_phase",
    "artifact_type",
    "skip_phases"
  ],
  "properties": {
    "requested_action": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._ -]*$"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "referenced_entities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "provided_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "missing_context": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "additionalProperties": true
          }
        ]
      }
    },
    "proposed_phase": {
      "type": [
        "string",
        "null"
      ]
    },
    "artifact_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "skip_phases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "reference": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": {
              "type": "string"
            },
            "entity_type": {
              "type": "string"
            },
            "kind": {
              "type": "string"
            },
            "id": {
              "type": "string"
            },
            "identifier": {
              "type": "string"
            },
            "value": {
              "type": "string"
            }
          }
        }
      ]
    },
    "artifact": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "artifact_type": {
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "template_id": {
              "type": "string"
            },
            "mode": {
              "type": "string"
            }
          }
        }
      ]
    }
  }
}
