{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "archive-record.schema.json",
  "title": "Agentic SDLC Logical Legacy Archive Record v1",
  "description": "Immutable declaration that specific legacy artifacts remain historical evidence but are intentionally outside one release manifest. This record does not itself move or delete files.",
  "type": "object",
  "required": [
    "id",
    "kind",
    "schema_version",
    "status",
    "release_manifest_ref",
    "legacy_history_policy",
    "reason",
    "artifacts",
    "source_paths",
    "source_hashes",
    "supersedes_ref",
    "generated_at",
    "record_hash",
    "hash_algorithm",
    "audit"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": { "const": "archive_record" },
    "schema_version": { "const": "archive-record:v1" },
    "status": { "enum": ["active", "superseded", "revoked"] },
    "release_manifest_ref": { "$ref": "#/$defs/hashed_ref" },
    "legacy_history_policy": { "const": "logically_archived_out_of_release_scope" },
    "reason": { "type": "string", "minLength": 1 },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/archived_artifact" }
    },
    "source_paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "source_hashes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/sha256" }
    },
    "supersedes_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/hashed_ref" }
      ]
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "record_hash": { "$ref": "#/$defs/sha256" },
    "hash_algorithm": { "const": "sha256:stable-json:v1" },
    "audit": { "$ref": "common.schema.json#/$defs/audit" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "hashed_ref": {
      "type": "object",
      "required": ["id", "path", "hash"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "hash": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "archived_artifact": {
      "type": "object",
      "required": ["path", "sha256", "classification", "excluded_from_release", "retention"],
      "properties": {
        "id": { "type": ["string", "null"] },
        "artifact_type": { "type": ["string", "null"] },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "classification": { "const": "legacy_history" },
        "excluded_from_release": { "const": true },
        "retention": { "enum": ["retain-in-place", "filesystem-archive-plan"] },
        "archive_plan_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/hashed_ref" }
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
