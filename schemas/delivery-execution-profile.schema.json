{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "delivery-execution-profile.schema.json",
  "title": "Agentic SDLC Delivery Execution Profile v1",
  "description": "Per-delivery autonomy selected explicitly for one pull request or local release. It may narrow, never expand, the linked requirement profiles.",
  "type": "object",
  "required": [
    "kind",
    "schema_version",
    "version",
    "id",
    "status",
    "delivery_id",
    "delivery_kind",
    "requirement_profile_refs",
    "story_refs",
    "contract_refs",
    "material_scope",
    "material_scope_hash",
    "requested_level",
    "phase_levels",
    "constraints",
    "checkpoints",
    "use_policy",
    "pull_request_target",
    "local_release_target",
    "authority_assurance",
    "approval_ref",
    "valid_from",
    "expires_at",
    "created_at",
    "updated_at",
    "extensions",
    "profile_hash",
    "hash_algorithm"
  ],
  "properties": {
    "kind": { "const": "delivery_execution_profile" },
    "schema_version": { "const": "delivery-execution-profile:v1" },
    "version": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["proposed", "active", "revoked"] },
    "delivery_id": { "type": "string", "minLength": 1 },
    "delivery_kind": { "enum": ["pull_request", "local_release"] },
    "requirement_profile_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/hashed_ref" }
    },
    "story_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/hashed_ref" }
    },
    "contract_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/hashed_ref" }
    },
    "material_scope": { "type": "object", "minProperties": 1 },
    "material_scope_hash": { "$ref": "#/$defs/sha256" },
    "requested_level": { "$ref": "#/$defs/autonomy_level" },
    "phase_levels": { "$ref": "#/$defs/phase_levels" },
    "constraints": { "$ref": "#/$defs/constraints" },
    "checkpoints": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" }
    },
    "use_policy": {
      "type": "object",
      "required": [
        "mode",
        "reusable_across_deliveries",
        "max_concurrent_runs",
        "close_on_terminal",
        "require_usage_receipt"
      ],
      "properties": {
        "mode": { "const": "exact-delivery" },
        "reusable_across_deliveries": { "const": false },
        "max_concurrent_runs": { "const": 1 },
        "close_on_terminal": { "const": true },
        "require_usage_receipt": { "const": true }
      },
      "additionalProperties": false
    },
    "pull_request_target": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/pull_request_target" }
      ]
    },
    "local_release_target": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/local_release_target" }
      ]
    },
    "authority_assurance": { "$ref": "#/$defs/authority_assurance" },
    "approval_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/hashed_ref" }
      ]
    },
    "valid_from": { "type": "string", "format": "date-time" },
    "expires_at": { "type": ["string", "null"], "format": "date-time" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "extensions": { "type": "object" },
    "profile_hash": { "$ref": "#/$defs/sha256" },
    "hash_algorithm": { "const": "sha256:stable-json:v1" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "active" } },
        "required": ["status"]
      },
      "then": {
        "properties": { "approval_ref": { "$ref": "#/$defs/hashed_ref" } }
      }
    },
    {
      "if": {
        "properties": { "delivery_kind": { "const": "pull_request" } },
        "required": ["delivery_kind"]
      },
      "then": {
        "properties": {
          "pull_request_target": { "$ref": "#/$defs/pull_request_target" },
          "local_release_target": { "type": "null" }
        }
      },
      "else": {
        "properties": {
          "pull_request_target": { "type": "null" },
          "local_release_target": { "$ref": "#/$defs/local_release_target" }
        }
      }
    },
    {
      "if": {
        "properties": { "requested_level": { "const": "supervised" } },
        "required": ["requested_level"]
      },
      "then": {
        "properties": {
          "phase_levels": { "$ref": "#/$defs/supervised_phase_levels" }
        }
      }
    },
    {
      "if": {
        "properties": { "requested_level": { "const": "checkpointed" } },
        "required": ["requested_level"]
      },
      "then": {
        "properties": {
          "phase_levels": { "$ref": "#/$defs/checkpointed_phase_levels" }
        }
      }
    }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "autonomy_level": { "enum": ["supervised", "checkpointed", "bounded-autonomous"] },
    "hashed_ref": {
      "type": "object",
      "required": ["id", "hash"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": ["string", "null"], "minLength": 1 },
        "hash": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "phase_levels": {
      "type": "object",
      "properties": {
        "discovery": { "$ref": "#/$defs/autonomy_level" },
        "analysis": { "$ref": "#/$defs/autonomy_level" },
        "design": { "$ref": "#/$defs/autonomy_level" },
        "implementation": { "$ref": "#/$defs/autonomy_level" },
        "validation": { "$ref": "#/$defs/autonomy_level" },
        "release": { "$ref": "#/$defs/autonomy_level" }
      },
      "additionalProperties": false
    },
    "supervised_phase_levels": {
      "type": "object",
      "properties": {
        "discovery": { "const": "supervised" },
        "analysis": { "const": "supervised" },
        "design": { "const": "supervised" },
        "implementation": { "const": "supervised" },
        "validation": { "const": "supervised" },
        "release": { "const": "supervised" }
      },
      "additionalProperties": false
    },
    "checkpointed_phase_levels": {
      "type": "object",
      "properties": {
        "discovery": { "enum": ["supervised", "checkpointed"] },
        "analysis": { "enum": ["supervised", "checkpointed"] },
        "design": { "enum": ["supervised", "checkpointed"] },
        "implementation": { "enum": ["supervised", "checkpointed"] },
        "validation": { "enum": ["supervised", "checkpointed"] },
        "release": { "enum": ["supervised", "checkpointed"] }
      },
      "additionalProperties": false
    },
    "constraints": {
      "type": "object",
      "required": [
        "allowed_tools",
        "allowed_capabilities",
        "allowed_environments",
        "allowed_write_paths",
        "forbidden_actions",
        "budget_ref"
      ],
      "properties": {
        "allowed_tools": { "$ref": "#/$defs/string_list" },
        "allowed_capabilities": { "$ref": "#/$defs/string_list" },
        "allowed_environments": { "$ref": "#/$defs/string_list" },
        "allowed_write_paths": { "$ref": "#/$defs/string_list" },
        "forbidden_actions": { "$ref": "#/$defs/string_list" },
        "budget_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/hashed_ref" }
          ]
        }
      },
      "additionalProperties": false
    },
    "string_list": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "pull_request_target": {
      "type": "object",
      "required": ["repository", "base_branch", "head_branch", "allowed_actions", "merge_allowed"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "base_branch": { "type": "string", "minLength": 1 },
        "head_branch": { "type": "string", "minLength": 1 },
        "allowed_actions": { "$ref": "#/$defs/string_list" },
        "merge_allowed": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "local_release_target": {
      "type": "object",
      "required": [
        "environment",
        "root_path",
        "allowed_write_paths",
        "allowed_actions",
        "smoke_tests",
        "rollback",
        "external_access_allowed",
        "production_access_allowed",
        "destructive_actions_allowed"
      ],
      "properties": {
        "environment": { "const": "local" },
        "root_path": { "type": "string", "minLength": 1 },
        "allowed_write_paths": { "$ref": "#/$defs/non_empty_string_list" },
        "allowed_actions": { "$ref": "#/$defs/non_empty_string_list" },
        "smoke_tests": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 2, "pattern": "^\\[.*\\]$" }
        },
        "rollback": {
          "type": "object",
          "required": ["required", "procedure"],
          "properties": {
            "required": { "const": true },
            "procedure": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "external_access_allowed": { "const": false },
        "production_access_allowed": { "const": false },
        "destructive_actions_allowed": { "const": false }
      },
      "additionalProperties": false
    },
    "non_empty_string_list": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "authority_assurance": {
      "oneOf": [
        {
          "type": "object",
          "required": ["mode", "source", "verified", "receipt_ref"],
          "properties": {
            "mode": { "const": "audit_only" },
            "source": { "const": "declared_cli_attribution" },
            "verified": { "const": false },
            "receipt_ref": { "type": "null" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["mode", "source", "verified", "receipt_ref"],
          "properties": {
            "mode": { "const": "host_verified" },
            "source": { "enum": ["host_approval_receipt", "ci_attestation"] },
            "verified": { "const": true },
            "receipt_ref": { "$ref": "#/$defs/hashed_ref" }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": false
}
