{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "claim.schema.json",
  "title": "Agentic SDLC Story Claim",
  "type": "object",
  "required": [
    "story_id",
    "agent",
    "branch",
    "status",
    "claimed_at"
  ],
  "properties": {
    "story_id": {
      "type": "string"
    },
    "agent": {
      "type": "string"
    },
    "branch": {
      "type": "string"
    },
    "status": {
      "enum": [
        "active",
        "released",
        "transferred",
        "cancelled"
      ]
    },
    "claimed_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "released_at": {
      "type": "string",
      "format": "date-time"
    },
    "release_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "audit": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
