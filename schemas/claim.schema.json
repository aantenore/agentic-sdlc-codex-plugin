{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aantenore/agentic-sdlc-codex-plugin/schemas/claim.schema.json",
  "title": "Agentic SDLC Story Claim",
  "type": "object",
  "required": [
    "story_id",
    "agent",
    "branch",
    "status",
    "claimed_at"
  ],
  "properties": {
    "story_id": {
      "type": "string"
    },
    "agent": {
      "type": "string"
    },
    "branch": {
      "type": "string"
    },
    "status": {
      "enum": [
        "active",
        "released",
        "transferred",
        "stale"
      ]
    },
    "claimed_at": {
      "type": "string"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "released_at": {
      "type": "string"
    },
    "release_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "audit": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
