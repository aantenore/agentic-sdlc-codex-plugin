{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "artifact-generator-receipt.schema.json",
  "title": "Agentic SDLC Artifact Generator Receipt v1",
  "description": "Attestation emitted by the capability that generated the real target-format artifact; render evidence remains separate.",
  "type": "object",
  "required": [
    "kind",
    "schema_version",
    "artifact_path",
    "artifact_sha256",
    "generator",
    "status",
    "generated_at"
  ],
  "properties": {
    "kind": {
      "const": "artifact_generator_receipt"
    },
    "schema_version": {
      "const": "artifact-generator-receipt:v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_path": {
      "type": "string",
      "minLength": 1
    },
    "artifact_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "generator": {
      "description": "Exact capability identifier; it must match delivery.generator in the approved output contract.",
      "type": "string",
      "minLength": 1
    },
    "status": {
      "const": "succeeded"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "executor": {
      "$ref": "common.schema.json#/$defs/actor"
    },
    "capability_ref": {
      "type": [
        "object",
        "null"
      ],
      "required": [
        "id",
        "hash"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "hash": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    },
    "receipt_hash": {
      "$ref": "#/$defs/sha256"
    },
    "hash_algorithm": {
      "const": "sha256:stable-json:v1"
    },
    "audit": {
      "$ref": "common.schema.json#/$defs/audit"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "dependentRequired": {
    "receipt_hash": ["hash_algorithm"],
    "hash_algorithm": ["receipt_hash"]
  },
  "additionalProperties": false
}
