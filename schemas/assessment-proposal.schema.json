{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "assessment-proposal.schema.json",
  "title": "Agentic SDLC Assessment Proposal v1",
  "description": "Immutable approval payload for the complete second-checkpoint execution tranche.",
  "type": "object",
  "required": [
    "kind", "schema_version", "version", "id", "status", "created_at", "updated_at", "objective",
    "baseline_ref", "scope", "story_reservation", "deliverable", "capabilities", "contract_draft",
    "route_intent", "write_set", "execution_budget", "security", "approvals", "authorization_ref",
    "application", "extensions", "proposal_hash", "hash_algorithm"
  ],
  "properties": {
    "kind": { "const": "assessment_proposal" },
    "schema_version": { "const": "assessment-proposal:v1" },
    "version": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "minLength": 1 },
    "status": {
      "enum": ["draft", "proposal_pending", "authorized", "running", "verifying", "completed", "exception_pending", "failed", "cancelled"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "objective": { "type": ["string", "null"] },
    "baseline_ref": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["id", "path", "approved_content_hash"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "path": { "type": "string", "minLength": 1 },
            "approved_content_hash": {
              "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/sha256" }]
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "scope": {
      "type": "object",
      "required": ["id", "title", "summary", "requirement_id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "requirement_id": { "type": "string", "minLength": 1 },
        "included": { "type": "array", "items": { "type": "string" } },
        "excluded": { "type": "array", "items": { "type": "string" } },
        "depth": { "type": "string" },
        "mode": { "enum": ["new", "reuse", "delta"] }
      },
      "additionalProperties": true
    },
    "story_reservation": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["id", "title", "phase", "acceptance_criteria"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "title": { "type": "string", "minLength": 1 },
            "phase": { "type": "string", "minLength": 1 },
            "acceptance_criteria": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
            "operation": { "enum": ["create", "reuse"] }
          },
          "additionalProperties": true
        }
      ]
    },
    "deliverable": {
      "type": "object",
      "required": ["artifact_type", "artifact_path", "template_id", "preset", "sections", "delivery"],
      "properties": {
        "artifact_type": { "type": "string", "minLength": 1 },
        "artifact_path": { "type": "string", "minLength": 1 },
        "template_id": { "type": "string", "minLength": 1 },
        "template_path": { "type": "string" },
        "template_source_sha256": { "$ref": "#/$defs/sha256" },
        "preset": { "type": ["string", "null"] },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              { "type": "object", "additionalProperties": true }
            ]
          }
        },
        "delivery": { "$ref": "output-template.schema.json#/$defs/delivery" },
        "verifier": { "type": "string" },
        "required_verification": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "required": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
        "allowed_tools": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
        "external_access": { "type": "boolean" },
        "production_access": { "type": "boolean" },
        "bindings": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
      },
      "additionalProperties": true
    },
    "contract_draft": { "type": ["object", "null"], "additionalProperties": true },
    "route_intent": {
      "oneOf": [{ "type": "null" }, { "$ref": "route-intent.schema.json" }]
    },
    "write_set": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["action", "subject_id", "path", "artifact_types"],
        "properties": {
          "action": { "type": "string", "minLength": 1 },
          "subject_id": { "type": "string", "minLength": 1 },
          "subject_hash": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/sha256" }] },
          "path": { "type": "string", "minLength": 1 },
          "artifact_types": { "type": "array", "uniqueItems": true, "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "execution_budget": {
      "oneOf": [{ "type": "null" }, { "$ref": "execution-budget.schema.json" }]
    },
    "security": {
      "type": "object",
      "properties": {
        "repository_content_trust": { "type": "string" },
        "embedded_instructions": { "type": "string" },
        "secret_redaction": { "type": "string" },
        "writes_limited_to_manifest": { "type": "boolean" },
        "external_access": { "type": "boolean" },
        "production_access": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "approvals": { "type": "array" },
    "authorization_ref": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 },
        { "$ref": "#/$defs/hashed_ref" }
      ]
    },
    "application": {
      "type": "object",
      "required": ["status", "idempotency_key"],
      "properties": {
        "status": { "type": "string", "minLength": 1 },
        "idempotency_key": { "type": "string", "minLength": 1 },
        "strategy": { "type": "string" },
        "preconditions": { "type": "array", "items": { "type": "string" } },
        "rollback": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "approval_boundary": {
      "type": "object",
      "properties": {
        "authorizes": { "type": "array", "items": { "type": "string" } },
        "does_not_authorize": { "type": "array", "items": { "type": "string" } },
        "exception_triggers": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "extensions": { "type": "object", "additionalProperties": true },
    "proposal_hash": { "$ref": "#/$defs/sha256" },
    "hash_algorithm": { "const": "sha256:stable-json:v1" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "hashed_ref": {
      "type": "object",
      "required": ["id", "hash"],
      "properties": {
        "id": { "type": "string" },
        "path": { "type": ["string", "null"] },
        "hash": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
