{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phase-lock.schema.json",
  "title": "Agentic SDLC Phase Lock",
  "type": "object",
  "required": [
    "id",
    "phase",
    "scope",
    "status",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "phase": {
      "enum": [
        "discovery",
        "analysis",
        "design",
        "implementation",
        "validation",
        "release"
      ]
    },
    "scope": {
      "type": "string"
    },
    "status": {
      "enum": [
        "active",
        "released",
        "cancelled",
        "expired"
      ]
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "audit": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
