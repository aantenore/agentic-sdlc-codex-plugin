{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "portfolio-manifest.schema.json",
  "title": "Change Observatory Portfolio Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "projects"
  ],
  "properties": {
    "schema_version": {
      "const": "portfolio-manifest:v1"
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "required": [
          "id",
          "path"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
