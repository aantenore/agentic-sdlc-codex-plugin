{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "delivery-action-receipt.schema.json",
  "title": "Exact delivery action authorization receipt",
  "type": "object",
  "required": [
    "id",
    "kind",
    "schema_version",
    "profile_ref",
    "delivery",
    "action",
    "effective_level",
    "checkpoint_required",
    "approval",
    "runtime_target",
    "action_details",
    "authorization_receipt_ref",
    "local_release_verification",
    "evidence",
    "outcome",
    "status",
    "authorized_by",
    "authorized_at",
    "audit",
    "receipt_hash",
    "hash_algorithm"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": { "const": "delivery_action_receipt" },
    "schema_version": { "const": "delivery-action-receipt:v1" },
    "profile_ref": { "$ref": "#/$defs/path_hashed_id_ref" },
    "delivery": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["pull_request", "local_release"] }
      },
      "additionalProperties": false
    },
    "action": { "type": "string", "minLength": 1 },
    "effective_level": { "enum": ["supervised", "checkpointed", "bounded-autonomous"] },
    "checkpoint_required": { "type": "boolean" },
    "approval": {
      "oneOf": [
        { "type": "null" },
        { "type": "object" }
      ]
    },
    "runtime_target": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["branch", "head_sha", "base_ref", "base_sha", "matching_remotes", "remote_fingerprint"],
          "properties": {
            "branch": { "type": "string", "minLength": 1 },
            "head_sha": { "type": "string", "minLength": 1 },
            "base_ref": { "type": "string", "minLength": 1 },
            "base_sha": { "type": "string", "minLength": 1 },
            "matching_remotes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
            "remote_fingerprint": { "$ref": "#/$defs/sha256" }
          },
          "additionalProperties": false
        }
      ]
    },
    "action_details": { "type": "object" },
    "authorization_receipt_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/path_hashed_id_ref" }
      ]
    },
    "local_release_verification": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["target_root", "allowed_write_paths", "smoke_tests", "smoke_test_receipts", "outcome", "evidence", "rollback"],
          "properties": {
            "target_root": { "type": "string", "minLength": 1 },
            "allowed_write_paths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
            "smoke_tests": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 2, "pattern": "^\\[.*\\]$" } },
            "smoke_test_receipts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["command", "cwd", "sandbox", "exit_code", "signal", "error_code", "outcome", "stdout_sha256", "stderr_sha256", "started_at", "finished_at"],
                "properties": {
                  "command": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
                  "cwd": { "type": "string", "minLength": 1 },
                  "sandbox": { "enum": ["macos-sandbox-exec-readonly-no-network", "linux-bwrap-readonly-no-network"] },
                  "exit_code": { "type": ["integer", "null"] },
                  "signal": { "type": ["string", "null"] },
                  "error_code": { "type": ["string", "null"] },
                  "outcome": { "enum": ["passed", "failed"] },
                  "stdout_sha256": { "$ref": "#/$defs/sha256" },
                  "stderr_sha256": { "$ref": "#/$defs/sha256" },
                  "started_at": { "type": "string", "format": "date-time" },
                  "finished_at": { "type": "string", "format": "date-time" }
                },
                "additionalProperties": false
              }
            },
            "outcome": { "const": "passed" },
            "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/path_hash" } },
            "rollback": {
              "type": "object",
              "required": ["required", "procedure"],
              "properties": {
                "required": { "const": true },
                "procedure": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "evidence": { "type": "array", "items": { "$ref": "#/$defs/path_hash" } },
    "outcome": { "type": ["string", "null"], "enum": [null, "passed", "failed"] },
    "status": { "enum": ["authorized", "completed"] },
    "authorized_by": { "$ref": "common.schema.json#/$defs/actor" },
    "authorized_at": { "type": "string", "format": "date-time" },
    "audit": { "$ref": "common.schema.json#/$defs/audit" },
    "receipt_hash": { "$ref": "#/$defs/sha256" },
    "hash_algorithm": { "const": "sha256:stable-json:v1" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "completed" } }, "required": ["status"] },
      "then": {
        "properties": {
          "authorization_receipt_ref": { "$ref": "#/$defs/path_hashed_id_ref" },
          "outcome": { "enum": ["passed", "failed"] },
          "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/path_hash" } }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "authorized" } }, "required": ["status"] },
      "then": {
        "properties": {
          "authorization_receipt_ref": { "const": null },
          "outcome": { "const": null },
          "local_release_verification": { "const": null }
        }
      }
    },
    {
      "if": {
        "properties": {
          "action": { "const": "git.push" }
        },
        "required": ["action"]
      },
      "then": {
        "properties": {
          "action_details": { "required": ["push", "base_precondition", "push_precondition"] }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "completed" },
          "outcome": { "const": "passed" },
          "action": { "const": "git.commit" }
        },
        "required": ["status", "outcome", "action"]
      },
      "then": { "properties": { "action_details": { "required": ["commit"] } } }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "completed" },
          "outcome": { "const": "passed" },
          "action": { "const": "git.push" }
        },
        "required": ["status", "outcome", "action"]
      },
      "then": {
        "properties": {
          "action_details": { "required": ["push", "base_precondition", "push_precondition", "remote_verification"] }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "completed" },
          "outcome": { "const": "passed" },
          "action": { "const": "pull_request.merge" }
        },
        "required": ["status", "outcome", "action"]
      },
      "then": {
        "properties": {
          "action_details": { "required": ["merge", "merge_precondition", "provider_verification"] }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "completed" },
          "outcome": { "const": "passed" },
          "action": { "const": "release.local" }
        },
        "required": ["status", "outcome", "action"]
      },
      "then": {
        "properties": {
          "local_release_verification": { "type": "object" }
        }
      }
    }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "path_hash": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "path_hashed_id_ref": {
      "type": "object",
      "required": ["id", "path", "hash"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "hash": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
