{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "capability-profile.schema.json",
  "title": "Agentic SDLC Capability Profile",
  "type": "object",
  "required": [
    "id",
    "schema_version",
    "status",
    "subject",
    "application_profile",
    "detected_stack",
    "evidence",
    "confidence",
    "source_paths",
    "source_hashes",
    "approvals",
    "audit"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "status": {
      "enum": [
        "proposed",
        "approved",
        "rejected"
      ]
    },
    "subject": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "story_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "requirement_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "phase": {
          "type": [
            "string",
            "null"
          ]
        },
        "scope": {
          "type": "string"
        }
      }
    },
    "application_profile": {
      "type": "object",
      "additionalProperties": true
    },
    "detected_stack": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "name",
          "type"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "source_path": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "integrations": {
      "type": "array"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "source_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "approvals": {
      "type": "array"
    },
    "audit": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
