{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contract.schema.json",
  "title": "Agentic SDLC Contract",
  "type": "object",
  "required": [
    "id",
    "schema_version",
    "project",
    "phase",
    "purpose",
    "owner_agent",
    "inputs",
    "outputs",
    "validation",
    "allowed_tools",
    "kb_writes",
    "human_gate",
    "execution_policy",
    "contextualization"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "project": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "project_id": {
          "type": "string"
        },
        "project_name": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "phase": {
      "enum": [
        "discovery",
        "analysis",
        "design",
        "implementation",
        "validation",
        "release"
      ]
    },
    "purpose": {
      "type": "string"
    },
    "owner_agent": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_contract_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "artifact_type",
          "template_id",
          "mode"
        ],
        "properties": {
          "artifact_type": {
            "type": "string"
          },
          "template_id": {
            "type": "string"
          },
          "mode": {
            "enum": [
              "reuse",
              "delta",
              "new"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "kb_writes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_gate": {
      "type": "boolean"
    },
    "execution_policy": {
      "type": "object",
      "required": [
        "runtime",
        "model",
        "reasoning",
        "notes"
      ],
      "properties": {
        "runtime": {
          "const": "codex"
        },
        "model": {
          "type": "object",
          "required": [
            "mode",
            "value"
          ],
          "properties": {
            "mode": {
              "enum": [
                "inherit",
                "override"
              ]
            },
            "value": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": true
        },
        "reasoning": {
          "type": "object",
          "required": [
            "mode",
            "level"
          ],
          "properties": {
            "mode": {
              "enum": [
                "inherit",
                "override"
              ]
            },
            "level": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": true
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "capability_policy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "skills": {
          "$ref": "#/$defs/capability_set"
        },
        "mcp": {
          "$ref": "#/$defs/capability_set"
        },
        "tools": {
          "$ref": "#/$defs/capability_set"
        },
        "approval_required_for": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "capability_bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "name",
          "binding_id",
          "target"
        ],
        "properties": {
          "type": {
            "enum": [
              "skill",
              "mcp",
              "tool"
            ]
          },
          "name": {
            "type": "string"
          },
          "binding_id": {
            "type": "string"
          },
          "target": {
            "type": "object",
            "additionalProperties": true
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "requires_approval_for": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "environment": {
            "type": [
              "string",
              "null"
            ]
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "capability_recommendation_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "approved_content_hash"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "profile_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "path": {
            "type": "string"
          },
          "approved_content_hash": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "contextualization": {
      "type": "object",
      "properties": {
        "summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "context_sources": {
          "type": "array"
        },
        "questions": {
          "type": "array"
        },
        "constraints": {
          "type": "array"
        },
        "assumptions": {
          "type": "array"
        },
        "open_questions": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "properties": {
        "created_by": {
          "type": "object",
          "additionalProperties": true
        },
        "updated_by": {
          "type": "object",
          "additionalProperties": true
        },
        "git": {
          "type": "object",
          "additionalProperties": true
        },
        "run": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "contract_id": {
            "type": "string"
          },
          "status": {
            "enum": [
              "approved",
              "changes_requested",
              "rejected"
            ]
          },
          "scope": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "additionalProperties": true
              }
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "approved_content_hash": {
            "type": [
              "string",
              "null"
            ]
          },
          "hash_algorithm": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "capability_set": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "additionalProperties": true
}
