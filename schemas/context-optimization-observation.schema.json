{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "context-optimization-observation.schema.json",
  "title": "Context Optimization Observation",
  "type": "object",
  "required": [
    "kind",
    "schema_version",
    "id",
    "execution_id",
    "proposal_hash",
    "phase",
    "observed_at",
    "provider",
    "scope",
    "counters",
    "delta",
    "assurance",
    "budget_effect",
    "source",
    "previous_observation_ref",
    "observation_hash",
    "hash_algorithm"
  ],
  "properties": {
    "kind": { "const": "context_optimization_observation" },
    "schema_version": { "const": "context-optimization-observation:v1" },
    "id": { "type": "string", "minLength": 1 },
    "execution_id": { "type": "string", "minLength": 1 },
    "proposal_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "phase": { "enum": ["apply", "checkpoint", "complete", "manual"] },
    "observed_at": { "type": "string", "format": "date-time" },
    "provider": {
      "type": "object",
      "required": ["id", "version", "contract"],
      "properties": {
        "id": { "const": "rtk" },
        "version": { "type": "string", "minLength": 1 },
        "contract": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "required": ["type", "project_scope_hash"],
      "properties": {
        "type": { "const": "project_root" },
        "project_scope_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "counters": { "$ref": "#/$defs/counters" },
    "delta": {
      "type": "object",
      "required": ["status", "commands", "estimated_command_output_tokens_before", "estimated_command_output_tokens_after", "estimated_tokens_avoided"],
      "properties": {
        "status": { "enum": ["baseline", "measured", "counter_reset", "provider_version_changed", "scope_changed"] },
        "commands": { "type": ["integer", "null"], "minimum": 0 },
        "estimated_command_output_tokens_before": { "type": ["integer", "null"], "minimum": 0 },
        "estimated_command_output_tokens_after": { "type": ["integer", "null"], "minimum": 0 },
        "estimated_tokens_avoided": { "type": ["integer", "null"], "minimum": 0 }
      },
      "additionalProperties": false
    },
    "assurance": {
      "type": "object",
      "required": ["classification", "trusted_exact"],
      "properties": {
        "classification": { "const": "advisory_estimated" },
        "trusted_exact": { "const": false }
      },
      "additionalProperties": false
    },
    "budget_effect": {
      "type": "object",
      "required": ["usage_adjustment_applied", "gate_override"],
      "properties": {
        "usage_adjustment_applied": { "const": 0 },
        "gate_override": { "const": false }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": ["command", "shell", "report_hash"],
      "properties": {
        "command": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "shell": { "const": false },
        "report_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "previous_observation_ref": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["id", "hash"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          },
          "additionalProperties": false
        }
      ]
    },
    "observation_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "hash_algorithm": { "const": "sha256:stable-json:v1" }
  },
  "$defs": {
    "counters": {
      "type": "object",
      "required": ["total_commands", "estimated_command_output_tokens_before", "estimated_command_output_tokens_after", "estimated_tokens_avoided", "estimated_savings_percent"],
      "properties": {
        "total_commands": { "type": "integer", "minimum": 0 },
        "estimated_command_output_tokens_before": { "type": "integer", "minimum": 0 },
        "estimated_command_output_tokens_after": { "type": "integer", "minimum": 0 },
        "estimated_tokens_avoided": { "type": "integer", "minimum": 0 },
        "estimated_savings_percent": { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
