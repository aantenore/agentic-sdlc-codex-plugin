{
  "config_schema_version": "sdlc-config:v1",
  "schema_version": "0.1.0",
  "kb_directories": [
    "baseline",
    "assessments",
    "budgets",
    "context-optimization",
    "contracts",
    "autonomy",
    "authorizations",
    "authorization-uses",
    "receipts",
    "capability-discovery",
    "output-contracts",
    "requirements",
    "stories",
    "work-items",
    "work-breakdown",
    "dependencies",
    "orchestration",
    "locks",
    "handoffs",
    "decisions",
    "assumptions",
    "risks",
    "tests",
    "traces",
    "releases",
    "manifests",
    "archive",
    "cache",
    "indexes",
    "reports"
  ],
  "indexable_extensions": [
    ".json",
    ".jsonl",
    ".md",
    ".txt",
    ".yaml",
    ".yml"
  ],
  "phase_order": [
    "discovery",
    "analysis",
    "design",
    "implementation",
    "validation",
    "release"
  ],
  "contract_generation": {
    "principle": "Contract templates are generic. Generated contracts must be contextualized for the target project by inspecting project KB artifacts, reading user-provided files, and asking questions when critical context is missing.",
    "context_sources": [
      ".sdlc/project.json",
      ".sdlc/requirements/",
      ".sdlc/stories/",
      ".sdlc/decisions/",
      ".sdlc/risks/",
      "user-provided files"
    ],
    "ask_when_missing": [
      "project objective",
      "target users or stakeholders",
      "constraints and non-functional requirements",
      "phase-specific inputs",
      "acceptance criteria",
      "required integrations",
      "approval boundaries"
    ],
    "required_contract_context": [
      "project",
      "contextualization.summary",
      "contextualization.context_sources",
      "contextualization.questions",
      "contextualization.constraints",
      "contextualization.assumptions"
    ]
  },
  "execution_policy": {
    "principle": "Contracts run inside Codex. If a contract does not explicitly override model or reasoning, spawned agents should inherit the main Codex thread configuration.",
    "runtime": "codex",
    "default_model": "inherit",
    "default_reasoning": "inherit",
    "reasoning_levels": [
      "inherit",
      "minimal",
      "low",
      "medium",
      "high"
    ]
  },
  "assessment_workflow": {
    "principle": "A normal assessment has exactly two user checkpoints: canonical project context and one immutable combined proposal. Internal records are applied idempotently after proposal authorization.",
    "normal_checkpoint_count": 2,
    "normal_checkpoints": [
      "context",
      "combined-proposal"
    ],
    "requested_actions": [
      "functional_analysis",
      "technical_analysis",
      "technical_assessment",
      "initial_technical_assessment",
      "project_technical_assessment",
      "project_assessment",
      "architecture_assessment",
      "technical_review"
    ],
    "proposal_schema": "schemas/assessment-proposal.schema.json",
    "workflow_schema": "schemas/assessment-workflow.schema.json",
    "approval_schema": "schemas/assessment-proposal-approval.schema.json",
    "application_schema": "schemas/assessment-application.schema.json",
    "task_start_receipt_schema": "schemas/task-start-receipt.schema.json",
    "storage_root": "assessments",
    "paths": {
      "proposals": "proposals",
      "workflows": "workflows",
      "approvals": "approvals",
      "applications": "applications"
    },
    "require_approved_baseline_before_proposal": true,
    "require_proposal_hash_for_authorization": true,
    "require_idempotent_application": true,
    "exception_triggers": [
      "install",
      "external-access",
      "secret",
      "production-access",
      "destructive-action",
      "out-of-scope-write",
      "material-proposal-change",
      "budget-extension"
    ]
  },
  "open_question_guidance": {
    "fallback": {
      "why_needed": "The answer replaces an unstated assumption with an explicit, reviewable proposal input.",
      "example_answers": {
        "it": [
          "Confermo l'opzione proposta.",
          "Non è ancora deciso: usa l'ipotesi indicata e segnala il limite."
        ],
        "en": [
          "I confirm the proposed option.",
          "It is not decided yet: use the stated assumption and record the limitation."
        ]
      },
      "effect_of_answer": "The answer is recorded in the relevant scope, assumption, or delivery field; a material change after approval creates a new proposal hash.",
      "does_not_authorize": "Answering an open question does not authorize execution, writes, external access, production access, or additional budget unless those boundaries are displayed in the proposal."
    },
    "categories": {
      "objective": {
        "keywords": [
          "objective",
          "goal",
          "outcome",
          "decision",
          "purpose",
          "obiettivo",
          "risultato",
          "decisione",
          "scopo"
        ],
        "why_needed": "The objective determines which evidence and recommendations are decision-relevant and prevents a generic assessment.",
        "example_answers": {
          "it": [
            "L'obiettivo è decidere se modernizzare l'architettura nei prossimi sei mesi."
          ],
          "en": [
            "The objective is to decide whether to modernize the architecture in the next six months."
          ]
        },
        "effect_of_answer": "It updates the assessment objective, scope emphasis, acceptance criteria, and intended decision in checkpoint 2."
      },
      "users_stakeholders": {
        "keywords": [
          "user",
          "users",
          "audience",
          "stakeholder",
          "owner",
          "utente",
          "utenti",
          "destinatario",
          "portatore di interesse",
          "responsabile"
        ],
        "why_needed": "Audience and stakeholder needs determine terminology, depth, prioritization, and which trade-offs must be made explicit.",
        "example_answers": {
          "it": [
            "Il documento è per CTO, team platform e responsabile sicurezza."
          ],
          "en": [
            "The document is for the CTO, platform team, and security owner."
          ]
        },
        "effect_of_answer": "It changes the audience, explanation depth, decision framing, and stakeholder-specific recommendations."
      },
      "constraints_nfr": {
        "keywords": [
          "constraint",
          "non-functional",
          "nfr",
          "security",
          "privacy",
          "performance",
          "availability",
          "compliance",
          "vincolo",
          "sicurezza",
          "prestazioni",
          "disponibilità",
          "conformità"
        ],
        "why_needed": "Constraints and non-functional requirements are architectural boundaries; omitting them can reverse a recommendation.",
        "example_answers": {
          "it": [
            "Dati in UE, disponibilità 99,9%, nessun downtime durante la migrazione."
          ],
          "en": [
            "EU data residency, 99.9% availability, and no migration downtime."
          ]
        },
        "effect_of_answer": "It updates explicit constraints, risk severity, architecture options, acceptance criteria, and excluded approaches."
      },
      "output_delivery": {
        "keywords": [
          "output",
          "artifact",
          "format",
          "delivery",
          "document",
          "report",
          "path",
          "formato",
          "consegna",
          "documento",
          "rapporto",
          "percorso"
        ],
        "why_needed": "The requested format and destination select the real generator, verification dimensions, artifact path, and delivery mode.",
        "example_answers": {
          "it": [
            "Consegna un DOCX in docs/assessment.docx più un riepilogo breve in chat."
          ],
          "en": [
            "Deliver a DOCX at docs/assessment.docx plus a short chat summary."
          ]
        },
        "effect_of_answer": "It changes the canonical artifact metadata, generator capability, render evidence, output path, and verification plan."
      },
      "integrations": {
        "keywords": [
          "integration",
          "api",
          "service",
          "database",
          "external",
          "endpoint",
          "integrazione",
          "servizio",
          "archivio dati",
          "esterno"
        ],
        "why_needed": "Integrations define system boundaries and may require separate credentials, external access, or production approval.",
        "example_answers": {
          "it": [
            "Considera Stripe e Salesforce solo dalla documentazione locale; non accedere ai tenant."
          ],
          "en": [
            "Assess Stripe and Salesforce from local documentation only; do not access the tenants."
          ]
        },
        "effect_of_answer": "It updates the component boundary, evidence sources, access policy, risks, and any exceptional authorization needed."
      },
      "approval_boundaries": {
        "keywords": [
          "approve",
          "approval",
          "authorize",
          "permission",
          "write",
          "install",
          "production",
          "boundary",
          "approvare",
          "approvazione",
          "autorizzare",
          "permesso",
          "scrittura",
          "installazione",
          "produzione"
        ],
        "why_needed": "An explicit boundary prevents a short answer from being reused as authority for unseen writes, tools, environments, or future artifacts.",
        "example_answers": {
          "it": [
            "Autorizzo solo lettura locale e scritture in .sdlc/ e docs/assessment.pdf; niente installazioni o produzione."
          ],
          "en": [
            "Authorize local reads and writes only to .sdlc/ and docs/assessment.pdf; no installs or production."
          ]
        },
        "effect_of_answer": "It changes the proposal write-set, capability constraints, authorization subjects/actions, and exception triggers."
      },
      "budget_time": {
        "keywords": [
          "budget",
          "cost",
          "time",
          "duration",
          "token",
          "deadline",
          "costo",
          "tempo",
          "durata",
          "scadenza"
        ],
        "why_needed": "A concrete, meterable tranche defines warning, reserve, stop, and partial-delivery behavior before work starts.",
        "example_answers": {
          "it": [
            "Massimo 60 minuti di tempo attivo; avvisa al 70% e 90%, riserva il 15% alla verifica."
          ],
          "en": [
            "At most 60 minutes of active time; warn at 70% and 90%, reserve 15% for verification."
          ]
        },
        "effect_of_answer": "It updates the immutable execution budget, metering policy, completion reserve, stop action, and amendment boundary."
      }
    }
  },
  "budget_policy": {
    "principle": "Checkpoint 2 approves the complete execution tranche. Active time and steps use hard limits, but exact values are accepted only from an explicitly configured trusted adapter with verified attestation; no adapter is trusted by default. Tokens are estimated and advisory. Cost is unavailable and non-binding unless a reliable metering/pricing adapter and currency are configured.",
    "schema": "schemas/execution-budget.schema.json",
    "amendment_schema": "schemas/budget-amendment.schema.json",
    "usage_receipt_schema": "schemas/execution-usage-receipt.schema.json",
    "metering_attestation_schema": "schemas/metering-attestation.schema.json",
    "storage_root": "budgets",
    "warning_thresholds_percent": [
      70,
      90
    ],
    "completion_reserve_percent": 15,
    "on_limit": "request_extension",
    "exact_metering": {
      "default_trust": "deny",
      "completion_freshness_seconds": 60,
      "trusted_sources": []
    },
    "metering_adapters": {
      "codeburn": {
        "enabled": true,
        "provider": "codex",
        "command": {
          "executable": "codeburn",
          "arguments": []
        },
        "metric_mapping": {
          "tokens": "tokens.total",
          "input_tokens": "tokens.input",
          "output_tokens": "tokens.output",
          "cache_read_tokens": "tokens.cache_read",
          "cache_write_tokens": "tokens.cache_write",
          "model_calls": "calls",
          "cost": "cost"
        }
      }
    },
    "defaults": {
      "warning_thresholds_percent": [
        70,
        90
      ],
      "completion_reserve_percent": 15,
      "scope": "proposal_execution_tree",
      "limits": {
        "active_time_seconds": {
          "unit": "seconds",
          "metering": "exact",
          "soft": 2700,
          "hard": 3600
        },
        "steps": {
          "unit": "steps",
          "metering": "exact",
          "soft": 40,
          "hard": 60
        },
        "tokens": {
          "unit": "tokens",
          "metering": "estimated",
          "soft": 200000
        }
      },
      "limit_policy": {
        "on_warning": "notify",
        "on_soft_limit": "checkpoint",
        "on_hard_limit": "stop",
        "on_metering_violation": "stop"
      },
      "extensions": {
        "on_limit": "request_extension",
        "automatic_extension": false,
        "active_time_excludes_user_wait": true,
        "active_time_excludes_external_wait": true,
        "aggregation": "proposal_execution_tree"
      }
    },
    "maxima": {},
    "presentation": {
      "require_concrete_values_in_checkpoint_2": true,
      "show_metering_accuracy": true,
      "show_completion_reserve": true,
      "show_limit_action": true,
      "omit_unreliable_cost_claims": true
    },
    "aggregation_scope": "story-including-subagents",
    "hard_limit_requires_exact_metering": true,
    "extensions_require_versioned_amendment": true
  },
  "context_optimization_policy": {
    "enabled": true,
    "mode": "automatic",
    "fallback": "native",
    "storage_root": "context-optimization",
    "observation_schema": "schemas/context-optimization-observation.schema.json",
    "provider": {
      "id": "rtk",
      "minimum_version": "0.43.0",
      "command": {
        "executable": "rtk",
        "arguments": []
      }
    },
    "telemetry": {
      "enabled": true,
      "include_in_budget_status": true,
      "auto_capture": [
        "apply",
        "checkpoint",
        "complete"
      ]
    },
    "budget_trigger_statuses": [
      "warning",
      "soft_limit",
      "completion_reserve"
    ]
  },
  "verification_policy": {
    "principle": "Verification claims are dimensioned; container validity never implies semantic or rendered correctness.",
    "receipt_schema": "schemas/verification-receipt.schema.json",
    "generator_receipt_schema": "schemas/artifact-generator-receipt.schema.json",
    "receipt_directory": ".sdlc/receipts/verification",
    "generator_receipt_directory": ".sdlc/receipts/generation",
    "dimensions": [
      "container_verified",
      "content_verified",
      "render_verified",
      "independent_verified"
    ],
    "require_generator_receipt": true,
    "non_native_requires_generator_receipt": true,
    "render_evidence_is_separate_from_generator_receipt": true,
    "legacy_passed_receipt_claim": "structurally-verified"
  },
  "authority_policy": {
    "mode": "audit_only",
    "usage_receipts_root": "authorization-uses",
    "allow_wildcards": false,
    "default_ttl_seconds": 86400,
    "trusted_host_keys": [],
    "require_proposal_binding_for_assessments": true,
    "require_validity_at_use_receipt": true
  },
  "autonomy_policy": {
    "enabled": true,
    "mode": "enforce_new_only",
    "principle": "Autonomy is negotiated per requirement as a ceiling and selected again for every pull request or local release. A downstream delivery, contract, capability, environment, or budget may narrow that level but never widen it.",
    "storage_root": "autonomy",
    "requirement_profile_schema": "schemas/requirement-execution-profile.schema.json",
    "delivery_profile_schema": "schemas/delivery-execution-profile.schema.json",
    "decision_schema": "schemas/autonomy-decision.schema.json",
    "allowed_levels": [
      "supervised",
      "checkpointed",
      "bounded-autonomous"
    ],
    "default_requirement_ceiling": "supervised",
    "legacy_default": "supervised",
    "fail_closed_on_unknown": true,
    "require_explicit_delivery_selection": true,
    "bounded_autonomous_requires_host_verified": true,
    "delivery_kinds": [
      "pull_request",
      "local_release"
    ],
    "presets": {
      "supervised": {
        "automatic_phases": [],
        "checkpoints": [
          "contract.approve",
          "task.start.confirm",
          "story.claim",
          "story.complete-step",
          "output.link",
          "sync.commit",
          "sync.push",
          "sync.pr",
          "release.local",
          "pull_request.merge",
          "deploy.remote"
        ]
      },
      "checkpointed": {
        "automatic_phases": [
          "analysis",
          "design",
          "implementation",
          "validation"
        ],
        "checkpoints": [
          "release.local",
          "pull_request.merge",
          "deploy.remote"
        ]
      },
      "bounded-autonomous": {
        "automatic_phases": [
          "analysis",
          "design",
          "implementation",
          "validation",
          "release"
        ],
        "checkpoints": [
          "pull_request.merge",
          "deploy.remote"
        ]
      }
    },
    "exception_triggers": [
      "requirement-change",
      "scope-expansion",
      "new-write-path",
      "new-tool-or-capability",
      "environment-change",
      "budget-extension",
      "secret-access",
      "external-access",
      "production-access",
      "global-install",
      "destructive-action",
      "irreversible-migration",
      "security-privacy-compliance-decision",
      "gate-bypass",
      "protected-branch-merge",
      "remote-deploy",
      "external-publication"
    ],
    "pull_request": {
      "require_repository": true,
      "require_base_branch": true,
      "require_head_branch": true,
      "never_reuse_for_another_delivery": true
    },
    "local_release": {
      "require_target_root": true,
      "require_smoke_test": true,
      "require_rollback": true,
      "writes_outside_workspace_require_checkpoint": true,
      "machine_global_changes_require_checkpoint": true
    }
  },
  "release_evidence_policy": {
    "manifest_schema": "schemas/release-manifest.schema.json",
    "gate_receipt_schema": "schemas/release-gate-receipt.schema.json",
    "archive_schema": "schemas/archive-record.schema.json",
    "archive_plan_schema": "schemas/archive-plan.schema.json",
    "manifest_directory": ".sdlc/releases/manifests",
    "gate_receipt_directory": ".sdlc/releases/gates",
    "archive_directory": ".sdlc/archive",
    "max_future_skew_seconds": 300,
    "require_proposal_and_receipt_lineage": true,
    "archive_transactional": true
  },
  "parallel_work": {
    "principle": "Parallel work is story-scoped. Each active story lane has one active claim, an auditable actor, a branch, trace events, and explicit release or handoff.",
    "unit_of_parallelism": "story",
    "branch_pattern": "codex/<story-id>",
    "branch_patterns": [
      "codex/<story-id>",
      "feature/<story-id>"
    ],
    "active_claim_status": "active",
    "stale_claim_policy": "expired active claims block implementation until released, renewed, or force-reclaimed by a human"
  },
  "work_breakdown_policy": {
    "principle": "Work breakdown is agreed with the user and stored in .sdlc. Story remains the main delivery and strict-gate unit; epic and task are optional internal aggregation/operational levels.",
    "levels": [
      "requirement",
      "epic",
      "story",
      "task"
    ],
    "default_flow": [
      "requirement",
      "story"
    ],
    "optional_levels": [
      "epic",
      "task"
    ],
    "delivery_unit": "story",
    "claimable_units": [
      "story",
      "task"
    ],
    "strict_gate_unit": "story",
    "task_gate": "light"
  },
  "output_consistency_policy": {
    "principle": "Every durable story output should resolve an approved project-wide output template before generation. Related stories should reuse the approved base artifact and create only an explicit delta unless the user approves a new structure.",
    "registry_path": ".sdlc/output-contracts/registry.json",
    "template_directory": ".sdlc/output-contracts/templates",
    "default_related_story_mode": "reuse+delta",
    "artifact_types": [
      "functional-analysis",
      "technical-analysis",
      "technical-decision-matrix",
      "test-strategy",
      "test-plan",
      "implementation-summary",
      "release-evidence"
    ],
    "approval_required_for": [
      "new_template",
      "template_structure_change",
      "duplicate_new_output",
      "project_wide_template_replacement"
    ],
    "agent_rules": [
      "Read the output registry before producing an artifact.",
      "Resolve the artifact type for the story and requirement.",
      "Prefer reuse plus delta when another story already covers the same requirement.",
      "Ask the user before introducing a new template or changing an approved output structure.",
      "Link every durable output to story, requirement, artifact path, template id, and reuse mode."
    ]
  },
  "routing_policy": {
    "principle": "The route router is language-agnostic. It consumes canonical intent JSON normalized by an LLM or Codex and never classifies raw text with linguistic keywords.",
    "canonical_intent_schema": "schemas/route-intent.schema.json",
    "routes": [
      "init_project",
      "onboard_existing_project",
      "ask_clarification",
      "intake_requirement",
      "classify_artifact",
      "decompose_stories",
      "create_contract",
      "discover_capabilities",
      "technical_decision",
      "confirm_phase_skip",
      "claim_and_implement",
      "validate_story",
      "release_story"
    ],
    "confidence": {
      "auto_route_min": 0.85,
      "confirm_min": 0.6,
      "ask_below": 0.45,
      "always_confirm": [
        "skip_phase",
        "create_story",
        "start_implementation",
        "create_canonical_artifact",
        "new_output_template",
        "duplicate_output"
      ]
    },
    "entity_types": {
      "story": [
        "story"
      ],
      "contract": [
        "contract"
      ],
      "requirement": [
        "requirement"
      ],
      "template": [
        "template",
        "output_template"
      ]
    },
    "canonical_actions": {
      "initialize_project": {
        "route": "init_project"
      },
      "init_project": {
        "route": "init_project"
      },
      "onboard_existing_project": {
        "route": "onboard_existing_project"
      },
      "existing_project_onboarding": {
        "route": "onboard_existing_project"
      },
      "create_baseline": {
        "route": "onboard_existing_project",
        "confirmation_key": "create_canonical_artifact"
      },
      "intake_requirement": {
        "route": "intake_requirement"
      },
      "classify_artifact": {
        "route": "classify_artifact",
        "requires_artifact_type": true
      },
      "decompose_stories": {
        "route": "decompose_stories",
        "confirmation_key": "create_story"
      },
      "create_story": {
        "route": "decompose_stories",
        "confirmation_key": "create_story"
      },
      "create_contract": {
        "route": "create_contract"
      },
      "discover_capabilities": {
        "route": "discover_capabilities",
        "confirmation_key": "discover_capabilities"
      },
      "capability_discovery": {
        "route": "discover_capabilities",
        "confirmation_key": "discover_capabilities"
      },
      "technical_decision": {
        "route": "technical_decision",
        "confirmation_key": "create_canonical_artifact",
        "default_artifact_type": "technical-decision-matrix"
      },
      "implement_story": {
        "route": "claim_and_implement",
        "confirmation_key": "start_implementation",
        "requires_story": true,
        "requires_contract": true
      },
      "start_implementation": {
        "route": "claim_and_implement",
        "confirmation_key": "start_implementation",
        "requires_story": true,
        "requires_contract": true
      },
      "validate_story": {
        "route": "validate_story",
        "requires_story": true
      },
      "release_story": {
        "route": "release_story",
        "requires_story": true
      },
      "skip_phase": {
        "route": "confirm_phase_skip",
        "confirmation_key": "skip_phase"
      },
      "functional_analysis": {
        "route": "classify_artifact",
        "confirmation_key": "create_canonical_artifact",
        "default_artifact_type": "functional-analysis",
        "requires_artifact_type": true
      },
      "technical_analysis": {
        "route": "classify_artifact",
        "confirmation_key": "create_canonical_artifact",
        "default_artifact_type": "technical-analysis",
        "requires_artifact_type": true
      },
      "technical_assessment": {
        "route": "classify_artifact",
        "confirmation_key": "create_canonical_artifact",
        "default_artifact_type": "technical-analysis",
        "requires_artifact_type": true
      },
      "initial_technical_assessment": {
        "route": "classify_artifact",
        "confirmation_key": "create_canonical_artifact",
        "default_artifact_type": "technical-analysis",
        "requires_artifact_type": true
      },
      "project_technical_assessment": {
        "route": "classify_artifact",
        "confirmation_key": "create_canonical_artifact",
        "default_artifact_type": "technical-analysis",
        "requires_artifact_type": true
      },
      "project_assessment": {
        "route": "classify_artifact",
        "confirmation_key": "create_canonical_artifact",
        "default_artifact_type": "technical-analysis",
        "requires_artifact_type": true
      },
      "architecture_assessment": {
        "route": "classify_artifact",
        "confirmation_key": "create_canonical_artifact",
        "default_artifact_type": "technical-analysis",
        "requires_artifact_type": true
      },
      "technical_review": {
        "route": "classify_artifact",
        "confirmation_key": "create_canonical_artifact",
        "default_artifact_type": "technical-analysis",
        "requires_artifact_type": true
      },
      "create_canonical_artifact": {
        "route": "classify_artifact",
        "confirmation_key": "create_canonical_artifact",
