  "effective_config": {
    "approval_policy": {
      "accepted_sources": [
        "explicit-user",
        "ci",
        "automation",
        "bootstrap"
      ],
      "agent_rules": [
        "Do not record --actor-type human unless the user explicitly approved the specific artifact.",
        "Use --approval-source explicit-user only with a summary or canonical evidence of the user's approval.",
        "By default, a user approval applies only to the artifact or decision just shown and summarized; do not reuse a short approval for future artifacts, templates, capability decisions, contracts, or task start confirmations.",
        "If the user explicitly specifies a broader approval level or autonomy scope, respect that level inside the stated boundaries and record later in-scope formal artifacts with --approval-source automation, --actor-type agent, and a summary/evidence of the delegated approval.",
        "Delegated automation approval must not expand scope to installs, deploys, secrets, external services, destructive commands, or unrelated work without another explicit approval.",
        "Use --approval-source bootstrap only for migration/provisional records; bootstrap approvals do not satisfy strict gates by default.",
        "Treat permission to implement or push as operational authorization, not as formal SDLC approval."
      ],
      "allow_bootstrap_approvals_in_strict_gate": false,
      "authorization_usage_receipt_directory": ".sdlc/authorization-uses",
      "authorization_usage_receipt_schema": "schemas/authorization-usage-receipt.schema.json",
      "close_authorization_on_workflow_terminal": true,
      "content_authorization_schema": "schemas/content-authorization.schema.json",
      "formal_approval_requires_explicit_source": true,
      "host_approval_receipt_directory": ".sdlc/receipts/host-approvals",
      "host_approval_receipt_schema": "schemas/host-approval-receipt.schema.json",
      "legacy_approval_behavior": "error",
      "principle": "Implementation authorization is not formal SDLC approval. Formal approvals must record an explicit source, approver, summary or evidence, and immutable subject hash.",
      "require_host_assurance_for_direct_human_or_ci_approval": false,
      "require_proposal_bound_authorization_for_assessments": true,
      "require_summary_or_evidence_for_automation": true,
      "require_summary_or_evidence_for_explicit_user": true,
      "require_usage_receipt_for_automation": true
    },
    "assessment_workflow": {
      "application_schema": "schemas/assessment-application.schema.json",
      "approval_schema": "schemas/assessment-proposal-approval.schema.json",
      "exception_triggers": [
        "install",
        "external-access",
        "secret",
        "production-access",
        "destructive-action",
        "out-of-scope-write",
        "material-proposal-change",
        "budget-extension"
      ],
      "normal_checkpoint_count": 2,
      "normal_checkpoints": [
        "context",
        "combined-proposal"
      ],
      "paths": {
        "applications": "applications",
        "approvals": "approvals",
        "proposals": "proposals",
        "workflows": "workflows"
      },
      "principle": "A normal assessment has exactly two user checkpoints: canonical project context and one immutable combined proposal. Internal records are applied idempotently after proposal authorization.",
      "proposal_schema": "schemas/assessment-proposal.schema.json",
      "requested_actions": [
        "functional_analysis",
        "technical_analysis",
        "technical_assessment",
        "initial_technical_assessment",
        "project_technical_assessment",
        "project_assessment",
        "architecture_assessment",
        "technical_review"
      ],
      "require_approved_baseline_before_proposal": true,
      "require_idempotent_application": true,
      "require_proposal_hash_for_authorization": true,
      "storage_root": "assessments",
      "task_start_receipt_schema": "schemas/task-start-receipt.schema.json",
      "workflow_schema": "schemas/assessment-workflow.schema.json"
    },
    "authority_policy": {
      "allow_wildcards": false,
      "default_ttl_seconds": 86400,
      "mode": "audit_only",
      "require_proposal_binding_for_assessments": true,
      "require_validity_at_use_receipt": true,
      "trusted_host_keys": [],
      "usage_receipts_root": "authorization-uses"
    },
    "autonomy_policy": {
      "allowed_levels": [
        "supervised",
        "checkpointed",
        "bounded-autonomous"
      ],
      "bounded_autonomous_requires_host_verified": true,
      "decision_schema": "schemas/autonomy-decision.schema.json",
      "default_requirement_ceiling": "supervised",
      "delivery_kinds": [
        "pull_request",
        "local_release"
      ],
      "delivery_profile_schema": "schemas/delivery-execution-profile.schema.json",
      "enabled": true,
      "exception_triggers": [
