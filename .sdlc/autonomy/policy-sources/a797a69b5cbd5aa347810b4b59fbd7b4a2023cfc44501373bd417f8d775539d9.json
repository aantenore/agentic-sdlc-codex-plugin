    "phase_order": [
      "discovery",
      "analysis",
      "design",
      "implementation",
      "validation",
      "release"
    ],
    "phases": {
      "analysis": {
        "allowed_tools": [
          "knowledge-base",
          "repo-read",
          "api-docs",
          "mock-generation"
        ],
        "human_gate": true,
        "inputs": [
          "approved requirements",
          "feature proposal",
          "constraints",
          "known integrations"
