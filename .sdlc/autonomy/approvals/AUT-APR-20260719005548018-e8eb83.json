    "id": "AUT-REQ-ENT-PORTFOLIO-R2-R2",
    "kind": "requirement_execution_profile",
    "material_scope": {
      "acceptance_criteria": [
        "An explicit manifest can aggregate up to 64 project roots in declared order without filesystem discovery, while isolating unavailable projects.",
        "The portfolio summary reports bounded active workflows, blockers, risks, budgets, dependencies and releases, and its health reflects real blocking states.",
        "Summary collection does not build full project detail; detail caches are globally bounded, observable, evicted and disposed when the server closes.",
        "A read-only portfolio status command returns compact stable JSON and exits without exposing bearer tokens or absolute project paths.",
        "The web interface never shows one project's data under another project, persists valid project navigation in the URL, and remains accessible in English and Italian.",
        "Filesystem identity remains exact on Windows for identifiers beyond Number.MAX_SAFE_INTEGER.",
        "Node.js 18, 20 and 24 tests, the complete Node.js 24 suite, static checks and bounded performance validation pass before merge."
      ],
      "budget": null,
      "capabilities": [
        "filesystem.read",
        "gh",
        "git",
        "git.commit",
        "git.push",
        "node",
        "npm",
        "pull_request.create",
        "pull_request.merge",
        "repository.write"
      ],
      "environment": [
        "ci",
        "local"
      ],
      "integrations": [
        "Change Observatory HTTP server and browser UI",
        "Agentic SDLC command catalog and CLI dispatcher"
      ],
      "nfrs": [
        "Memory, file reads, concurrency, payloads and caches remain deterministically bounded.",
        "Errors in one project cannot prevent healthy projects from being inspected."
      ],
      "non_goals": [
        "Do not publish a package, create a release or install locally in this delivery.",
        "Do not discover projects by scanning parent folders."
      ],
      "objective": "Provide one explicit, read-only and bounded view of multiple Agentic SDLC projects, with useful operational health and lazy project detail; include the package manifest and portfolio schema required to distribute the feature.",
      "release_target": null,
      "requirement_constraints": [
        "Manifest size is limited to 256 KiB, project count to 64, collection concurrency to 4 and summary previews to 8.",
        "The portfolio is read-only and must preserve single-project Observatory behavior."
      ],
      "scope": "Provide one explicit, read-only and bounded view of multiple Agentic SDLC projects, with useful operational health and lazy project detail; include the package manifest and portfolio schema required to distribute the feature.",
