{
  "schema_version": "agentic-sdlc-redaction-policy-source:v1",
  "algorithm": "legacy_evidence_v1",
  "replacement": "[REDACTED]",
  "limits": {
    "maxDepth": 24,
    "maxNodes": 10000,
    "maxStringLength": 262144,
    "maxOutputChars": 1048576,
    "maxMatches": 2000,
    "maxPatterns": 64,
    "maxPatternLength": 512
  },
  "sensitive_keys": [
    "accesstoken",
    "apikey",
    "authorization",
    "clientsecret",
    "cookie",
    "password",
    "privatekey",
    "refreshtoken",
    "secret",
    "setcookie",
    "token"
  ],
  "detectors": [
    {
      "name": "common_access_token",
      "source": "\\b(?:AKIA[A-Z0-9]{16}|gh[opsu]_[A-Za-z0-9_]{20,}|github_pat_[A-Za-z0-9_]{20,}|glpat-[A-Za-z0-9_-]{20,}|sk_(?:live|test)_[A-Za-z0-9_-]{16,}|xox[baprs]-[A-Za-z0-9-]{16,})\\b",
      "flags": "gu"
    },
    {
      "name": "bearer_value",
      "source": "(?<=\\bBearer\\s)[A-Za-z0-9._~+/=-]{16,}",
      "flags": "giu"
    },
    {
      "name": "generic_high_entropy_candidate",
      "source": "\\b[A-Za-z0-9_-]{32,}\\b",
      "flags": "gu"
    },
    {
      "name": "email",
      "engine": "legacy_email_linear_v1"
    }
  ],
  "identifier_allow_patterns": [
    {
      "name": "sha_digest",
      "source": "^(?:(?:sha(?:1|224|256|384|512))[:=-])?(?:[a-f0-9]{40}|[a-f0-9]{56}|[a-f0-9]{64}|[a-f0-9]{96}|[a-f0-9]{128})$",
      "flags": "giu"
    },
    {
      "name": "uuid",
      "source": "^[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}$",
      "flags": "giu"
    },
    {
      "name": "correlation_id",
      "source": "^corr-[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}$",
      "flags": "giu"
    },
    {
      "name": "authorization_action_id",
      "source": "^AUT-ACT-\\d{17}-[a-f0-9]{6}$",
      "flags": "gu"
    }
  ],
  "credential_assignment_detector": null,
  "semantics": {
    "credential_assignments": false,
    "legacy_evidence_v1": true
  }
}
