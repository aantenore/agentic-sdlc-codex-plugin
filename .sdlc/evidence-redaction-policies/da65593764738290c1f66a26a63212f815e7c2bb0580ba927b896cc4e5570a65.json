{
  "schema_version": "agentic-sdlc-redaction-policy-source:v1",
  "algorithm": "operational_evidence_v1",
  "replacement": "[REDACTED]",
  "limits": {
    "maxDepth": 24,
    "maxNodes": 10000,
    "maxStringLength": 262144,
    "maxOutputChars": 1048576,
    "maxMatches": 2000,
    "maxPatterns": 64,
    "maxPatternLength": 512
  },
  "sensitive_keys": [
    "accesstoken",
    "apikey",
    "authorization",
    "clientsecret",
    "cookie",
    "password",
    "privatekey",
    "refreshtoken",
    "secret",
    "setcookie",
    "token"
  ],
  "detectors": [
    {
      "name": "common_access_token",
      "source": "\\b(?:AKIA[A-Z0-9]{16}|gh[opsur]_[A-Za-z0-9_]{20,262144}|github_pat_[A-Za-z0-9_]{20,262144}|glpat-[A-Za-z0-9_-]{20,262144}|sk-(?:proj-)?[A-Za-z0-9_-]{20,262144}|sk_(?:live|test)_[A-Za-z0-9_-]{16,262144}|xox[baprs]-[A-Za-z0-9-]{16,262144})\\b",
      "flags": "gu"
    },
    {
      "name": "bearer_credential",
      "source": "\\bBearer\\s+[A-Za-z0-9._~+/=-]{16,262144}",
      "flags": "giu"
    },
    {
      "name": "basic_credential",
      "source": "\\bBasic\\s+[A-Za-z0-9+/]{8,262144}={0,2}",
      "flags": "giu"
    },
    {
      "name": "json_web_token",
      "source": "\\beyJ[A-Za-z0-9_-]{5,4096}\\.[A-Za-z0-9_-]{5,131072}\\.[A-Za-z0-9_-]{10,8192}\\b",
      "flags": "gu"
    },
    {
      "name": "cookie_header",
      "source": "\\b(?:Set-Cookie|Cookie)\\s*:\\s*[^\\r\\n]{1,262144}",
      "flags": "giu"
    },
    {
      "name": "url_userinfo",
      "source": "\\b[a-z][a-z0-9+.-]{0,20}:\\/\\/[^/\\s:?#]{0,262144}:[^/\\s?#]{0,262144}@",
      "flags": "giu"
    },
    {
      "name": "private_key_block",
      "source": "-----BEGIN [A-Z ]{0,32}PRIVATE KEY-----[\\s\\S]{0,262144}?(?:-----END [A-Z ]{0,32}PRIVATE KEY-----|$)",
      "flags": "gu"
    },
    {
      "name": "email",
      "source": "\\b[^\\s@]{1,64}@[^\\s@]{1,189}\\.[^\\s@]{1,63}\\b",
      "flags": "giu"
    }
  ],
  "identifier_allow_patterns": [
    {
      "name": "sha_digest",
      "source": "^(?:(?:sha(?:1|224|256|384|512))[:=-])?(?:[a-f0-9]{40}|[a-f0-9]{56}|[a-f0-9]{64}|[a-f0-9]{96}|[a-f0-9]{128})$",
      "flags": "giu"
    },
    {
      "name": "uuid",
      "source": "^[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}$",
      "flags": "giu"
    },
    {
      "name": "correlation_id",
      "source": "^corr-[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}$",
      "flags": "giu"
    },
    {
      "name": "authorization_action_id",
      "source": "^AUT-ACT-\\d{17}-[a-f0-9]{6}$",
      "flags": "gu"
    }
  ],
  "credential_assignment_detector": {
    "name": "credential_assignment_prefix",
    "source": "(?:[\"'](?=[A-Za-z0-9_])|\\b)[A-Za-z0-9_]{0,128}(?:access[_-]?token|api[_-]?key|authorization|client[_-]?secret|password|private[_-]?key|refresh[_-]?token|secret[_-]?access[_-]?key|secret[_-]?key|secret|storage[_-]?account[_-]?key|token)[\"']?\\s*[:=]\\s*",
    "flags": "giu"
  },
  "semantics": {
    "credential_assignments": true,
    "legacy_evidence_v1": false
  }
}
