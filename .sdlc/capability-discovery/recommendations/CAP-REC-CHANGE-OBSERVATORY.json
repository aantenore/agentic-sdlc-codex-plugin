  "execution_policy_suggestions": {
    "reasoning": "inherit",
    "notes": [
      "Preserve the dependency-free Node.js runtime.",
      "Use modular browser-native ES modules and code-native UI rather than adding a build tool.",
      "Use browser QA only against the local loopback observatory."
    ]
  },
  "decision_matrix": [
    {
      "option": "Browser-native ES modules plus Node HTTP",
      "fit": "best",
      "recommendation": "use",
      "rationale": "Ships directly in the plugin, requires no install/build step, remains modular and cross-platform."
    },
    {
      "option": "React plus Vite",
      "fit": "good UI ergonomics",
      "recommendation": "defer",
      "rationale": "Adds build artifacts and dependencies that are unnecessary for this bounded local tool."
    },
    {
      "option": "External hosted dashboard",
      "fit": "poor",
      "recommendation": "reject",
      "rationale": "Violates local-first evidence and privacy boundaries."
    }
  ],
