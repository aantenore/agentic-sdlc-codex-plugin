{
  "name": "agentic-sdlc-codex-plugin",
  "version": "0.6.0",
  "description": "Codex plugin for project contextualization, verified assessments, and traceable software delivery.",
  "type": "module",
  "bin": {
    "agentic-sdlc": "./bin/agentic-sdlc.mjs"
  },
  "engines": {
    "node": ">=18.18"
  },
  "files": [
    ".codex-plugin/",
    "assets/",
    "bin/",
    "docs/",
    "lib/",
    "schemas/",
    "scripts/",
    "skills/",
    "templates/"
  ],
  "scripts": {
    "check": "node --check bin/agentic-sdlc.mjs && node --check scripts/generate-plugin-assets.mjs",
    "doctor": "node bin/agentic-sdlc.mjs doctor",
    "smoke": "node bin/agentic-sdlc.mjs --help",
    "test": "node --test"
  },
  "keywords": [
    "codex",
    "sdlc",
    "agentic",
    "knowledge-base"
  ],
  "author": "Antonio Antenore",
  "license": "MIT"
}
